<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="flex flex-wrap gap-2 mb-4">
        <button onclick="toSlug()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">✨ 生成 Slug</button>
        <button onclick="copyResult()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">📋 复制</button>
        <button onclick="clearAll()" class="px-4 py-2 bg-white border border-gray-300 text-gray-500 rounded-lg hover:bg-gray-50 text-sm font-medium">清空</button>
      </div>

      <div class="flex flex-wrap gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">分隔符</label>
          <select id="slug-separator" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
            <option value="-">连字符 (-)</option>
            <option value="_">下划线 (_)</option>
            <option value="">无分隔</option>
          </select>
        </div>
        <div>
          <label class="flex items-center gap-1.5 mt-6 text-sm text-gray-600 cursor-pointer">
            <input type="checkbox" id="slug-lowercase" checked> 全小写
          </label>
        </div>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">输入文本</label>
        <textarea id="slug-input" rows="4" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" spellcheck="false" oninput="toSlug()" placeholder="输入标题或文本...">Hello World! This is a Title</textarea>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Slug 结果</label>
        <div id="slug-output" class="w-full min-h-[3rem] px-4 py-3 border border-gray-300 rounded-lg font-mono text-sm bg-blue-50 text-blue-800 break-all"></div>
      </div>

      <div class="p-4 bg-gray-50 rounded-lg">
        <h3 class="text-sm font-semibold text-gray-700 mb-2">💡 说明</h3>
        <ul class="text-xs text-gray-500 space-y-1">
          <li>• 将文本转换为 URL 友好的 Slug 格式</li>
          <li>• 移除非字母数字字符，空格替换为分隔符</li>
          <li>• 支持中文（保留原文，非转义）</li>
          <li>• 常用于博客 URL、文章别名等</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<script>
const inputEl = document.getElementById('slug-input');
const outputEl = document.getElementById('slug-output');
const separatorEl = document.getElementById('slug-separator');
const lowercaseEl = document.getElementById('slug-lowercase');

inputEl.addEventListener('input', toSlug);
separatorEl.addEventListener('change', toSlug);
lowercaseEl.addEventListener('change', toSlug);

function toSlug() {
  let text = inputEl.value;
  if (!text) { outputEl.textContent = ''; return; }

  const sep = separatorEl.value || '-';
  const toLower = lowercaseEl.checked;

  // Convert to slug
  let slug = text
    .replace(/[^\w\u4e00-\u9fff\s-]/g, '')  // remove non-word (keep Chinese)
    .replace(/[\s_-]+/g, sep)                // spaces/underscores/hyphens to sep
    .replace(new RegExp('^' + sep + '+|' + sep + '+$', 'g'), '');  // trim sep

  if (toLower) slug = slug.toLowerCase();
  if (!sep && toLower) slug = slug.replace(/\s+/g, '');

  outputEl.textContent = slug || '(空)';
}

function copyResult() {
  const text = outputEl.textContent;
  if (!text || text === '(空)') return;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('[onclick="copyResult()"]');
    btn.textContent = '✅ 已复制';
    setTimeout(() => btn.textContent = '📋 复制', 1500);
  })
      .catch(function(err) { console.error(err); });;
}

function clearAll() { inputEl.value = ''; outputEl.textContent = ''; }
</script>
