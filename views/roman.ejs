<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="flex flex-wrap gap-2 mb-4">
        <button onclick="toRoman()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">→ 罗马数字</button>
        <button onclick="fromRoman()" class="px-4 py-2 bg-gray-800 text-white rounded-lg hover:bg-gray-900 text-sm font-medium">← 转阿拉伯数字</button>
        <button onclick="copyResult()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">📋 复制</button>
        <button onclick="clearAll()" class="px-4 py-2 bg-white border border-gray-300 text-gray-500 rounded-lg hover:bg-gray-50 text-sm font-medium">清空</button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">阿拉伯数字（1-3999）</label>
          <input id="arabic-input" type="number" min="1" max="3999" value="2024"
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg text-lg font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
                 oninput="toRoman()">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">罗马数字</label>
          <input id="roman-input" type="text" value="MMXXIV"
                 class="w-full px-4 py-3 border border-gray-300 rounded-lg text-lg font-mono bg-gray-50 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
                 oninput="fromRoman()">
        </div>
      </div>

      <div class="p-4 bg-gray-50 rounded-lg">
        <h3 class="text-sm font-semibold text-gray-700 mb-2">📖 罗马数字规则</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-xs">
          <div class="bg-white rounded p-2"><b>I</b> = 1</div>
          <div class="bg-white rounded p-2"><b>V</b> = 5</div>
          <div class="bg-white rounded p-2"><b>X</b> = 10</div>
          <div class="bg-white rounded p-2"><b>L</b> = 50</div>
          <div class="bg-white rounded p-2"><b>C</b> = 100</div>
          <div class="bg-white rounded p-2"><b>D</b> = 500</div>
          <div class="bg-white rounded p-2"><b>M</b> = 1000</div>
          <div class="bg-white rounded p-2">范围: 1 ~ 3999</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const ROMAN_NUM = [
  [1000, 'M'], [900, 'CM'], [500, 'D'], [400, 'CD'],
  [100, 'C'], [90, 'XC'], [50, 'L'], [40, 'XL'],
  [10, 'X'], [9, 'IX'], [5, 'V'], [4, 'IV'], [1, 'I']
];

const arabicInput = document.getElementById('arabic-input');
const romanInput = document.getElementById('roman-input');

function toRoman() {
  let num = parseInt(arabicInput.value);
  if (isNaN(num) || num < 1) { num = 1; arabicInput.value = 1; }
  if (num > 3999) { num = 3999; arabicInput.value = 3999; }
  let result = '';
  for (const [val, sym] of ROMAN_NUM) {
    while (num >= val) { result += sym; num -= val; }
  }
  romanInput.value = result;
}

function fromRoman() {
  const str = romanInput.value.toUpperCase().trim();
  if (!str) { arabicInput.value = ''; return; }
  let result = 0;
  let i = 0;
  for (const [val, sym] of ROMAN_NUM) {
    while (str.startsWith(sym, i)) { result += val; i += sym.length; }
  }
  arabicInput.value = result > 3999 ? result : result;
}

function copyResult() {
  const text = romanInput.value;
  if (!text) return;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('[onclick="copyResult()"]');
    btn.textContent = '✅ 已复制';
    setTimeout(() => btn.textContent = '📋 复制', 1500);
  })
      .catch(function(err) { console.error(err); });;
}

function clearAll() { arabicInput.value = ''; romanInput.value = ''; }

toRoman();
</script>
