<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="flex flex-wrap gap-2 mb-4">
        <select id="cipher-type" class="px-3 py-2 border border-gray-300 rounded-lg text-sm">
          <option value="caesar">凯撒密码</option>
          <option value="vigenere">Vigenère 密码</option>
          <option value="atbash">Atbash 密码</option>
          <option value="rot47">ROT47</option>
        </select>
        <button onclick="encrypt()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">🔒 加密</button>
        <button onclick="decrypt()" class="px-4 py-2 bg-gray-800 text-white rounded-lg hover:bg-gray-900 text-sm font-medium">🔓 解密</button>
        <button onclick="copyResult()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">📋 复制</button>
        <button onclick="clearAll()" class="px-4 py-2 bg-white border border-gray-300 text-gray-500 rounded-lg hover:bg-gray-50 text-sm font-medium">清空</button>
      </div>

      <div id="cipher-options" class="mb-4">
        <div id="key-option" class="flex items-center gap-2">
          <label class="text-sm text-gray-600">密钥:</label>
          <input id="cipher-key" type="text" value="key" class="px-3 py-1.5 border border-gray-300 rounded text-sm w-32">
          <label class="text-sm text-gray-600 ml-2">偏移:</label>
          <input id="cipher-shift" type="number" min="1" max="25" value="3" class="px-3 py-1.5 border border-gray-300 rounded text-sm w-20">
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">原文</label>
          <textarea id="cipher-input" rows="6" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" spellcheck="false">HELLO WORLD</textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">结果</label>
          <textarea id="cipher-output" rows="6" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm bg-gray-50 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" readonly></textarea>
        </div>
      </div>

      <div class="p-4 bg-gray-50 rounded-lg">
        <h3 class="text-sm font-medium text-gray-700 mb-2">💡 关于密码</h3>
        <p id="cipher-info" class="text-xs text-gray-500">凯撒密码：每个字母按固定偏移量移位，是最经典的替换密码。</p>
      </div>
    </div>
  </div>
</div>

<script>
const cipherInfo = {
  caesar: '凯撒密码：每个字母按固定偏移量移位，是最经典的替换密码。',
  vigenere: 'Vigenère 密码：使用关键词对每个字母进行不同偏移的多表替换密码。',
  atbash: 'Atbash 密码：字母表反转映射（A↔Z, B↔Y, ...），是希伯来字母的古老密码。',
  rot47: 'ROT47：对 ASCII 33-126 个字符循环移位 47 位，覆盖字母数字和符号。'
};

document.getElementById('cipher-type').addEventListener('change', function() {
  document.getElementById('cipher-info').textContent = cipherInfo[this.value];
  document.getElementById('key-option').style.display = this.value === 'vigenere' ? 'flex' : 'none';
  document.getElementById('cipher-shift').parentElement.style.display = this.value === 'caesar' ? 'flex' : 'none';
});

function encrypt() {
  const type = document.getElementById('cipher-type').value;
  const text = document.getElementById('cipher-input').value;
  const shift = parseInt(document.getElementById('cipher-shift').value) || 3;
  const key = document.getElementById('cipher-key').value || 'key';

  switch (type) {
    case 'caesar': document.getElementById('cipher-output').value = caesar(text, shift); break;
    case 'vigenere': document.getElementById('cipher-output').value = vigenere(text, key, true); break;
    case 'atbash': document.getElementById('cipher-output').value = atbash(text); break;
    case 'rot47': document.getElementById('cipher-output').value = rot47(text); break;
  }
}

function decrypt() {
  const type = document.getElementById('cipher-type').value;
  const text = document.getElementById('cipher-input').value;
  const shift = parseInt(document.getElementById('cipher-shift').value) || 3;
  const key = document.getElementById('cipher-key').value || 'key';

  switch (type) {
    case 'caesar': document.getElementById('cipher-output').value = caesar(text, 26 - shift); break;
    case 'vigenere': document.getElementById('cipher-output').value = vigenere(text, key, false); break;
    case 'atbash': document.getElementById('cipher-output').value = atbash(text); break;
    case 'rot47': document.getElementById('cipher-output').value = rot47(text); break;
  }
}

function caesar(text, shift) {
  return text.split('').map(ch => {
    const code = ch.charCodeAt(0);
    if (code >= 65 && code <= 90) return String.fromCharCode(((code - 65 + shift) % 26) + 65);
    if (code >= 97 && code <= 122) return String.fromCharCode(((code - 97 + shift) % 26) + 97);
    return ch;
  }).join('');
}

function vigenere(text, key, encrypting) {
  const keyUpper = key.toUpperCase().replace(/[^A-Z]/g, '');
  if (!keyUpper) return text;
  let keyIdx = 0;
  return text.split('').map(ch => {
    const code = ch.charCodeAt(0);
    let base;
    if (code >= 65 && code <= 90) base = 65;
    else if (code >= 97 && code <= 122) base = 97;
    else return ch;

    const keyShift = keyUpper[keyIdx % keyUpper.length].charCodeAt(0) - 65;
    keyIdx++;
    const shift = encrypting ? keyShift : (26 - keyShift);
    return String.fromCharCode(((code - base + shift) % 26) + base);
  }).join('');
}

function atbash(text) {
  return text.split('').map(ch => {
    const code = ch.charCodeAt(0);
    if (code >= 65 && code <= 90) return String.fromCharCode(90 - (code - 65));
    if (code >= 97 && code <= 122) return String.fromCharCode(122 - (code - 97));
    return ch;
  }).join('');
}

function rot47(text) {
  return text.split('').map(ch => {
    const code = ch.charCodeAt(0);
    if (code >= 33 && code <= 126) return String.fromCharCode(33 + ((code - 33 + 47) % 94));
    return ch;
  }).join('');
}

function copyResult() {
  const text = document.getElementById('cipher-output').value;
  if (!text) return;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('[onclick="copyResult()"]');
    btn.textContent = '✅ 已复制';
    setTimeout(() => btn.textContent = '📋 复制', 1500);
  })
      .catch(function(err) { console.error(err); });;
}

function clearAll() {
  document.getElementById('cipher-input').value = '';
  document.getElementById('cipher-output').value = '';
}
</script>
