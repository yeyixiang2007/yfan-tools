<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div id="upload-area" class="border-2 border-dashed border-gray-300 rounded-xl p-12 text-center hover:border-blue-400 transition cursor-pointer" onclick="document.getElementById('file-input').click()">
        <div class="text-5xl mb-3">🖼️</div>
        <p class="text-gray-500 mb-1">点击上传图片</p>
        <p class="text-xs text-gray-400">支持 JPG / PNG / WebP，建议 2000px 以内</p>
        <input id="file-input" type="file" accept="image/*" class="hidden" onchange="loadImage(event)">
      </div>

      <div id="result-area" class="hidden mt-4 space-y-4">
        <div class="flex flex-wrap gap-4">
          <div class="flex-1 min-w-[200px]">
            <img id="preview-img" class="w-full max-h-64 object-contain rounded-lg border border-gray-200">
          </div>
          <div class="flex-1 min-w-[200px]">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-medium text-gray-700">🎨 提取的配色</span>
              <button onclick="exportPalette()" class="px-3 py-1.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-xs font-medium">📋 导出</button>
            </div>
            <div id="color-swatches" class="space-y-1.5"></div>
          </div>
        </div>

        <div class="flex flex-wrap gap-2">
          <button onclick="setColors(5)" class="px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-xs hover:bg-gray-50">提取 5 色</button>
          <button onclick="setColors(8)" class="px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-xs hover:bg-gray-50">提取 8 色</button>
          <button onclick="setColors(12)" class="px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-xs hover:bg-gray-50">提取 12 色</button>
          <span class="text-xs text-gray-400 self-center ml-2">当前: <span id="color-count">8</span> 色</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
let currentColors = [];
let colorCount = 8;

function loadImage(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(ev) {
    const img = new Image();
    img.onload = function() {
      document.getElementById('preview-img').src = ev.target.result;
      document.getElementById('upload-area').classList.add('hidden');
      document.getElementById('result-area').classList.remove('hidden');
      extractColors(img);
    };
    img.src = ev.target.result;
  };
  reader.readAsDataURL(file);
}

function extractColors(img) {
  const canvas = document.createElement('canvas');
  const scale = Math.min(1, 200 / Math.max(img.width, img.height));
  canvas.width = Math.round(img.width * scale);
  canvas.height = Math.round(img.height * scale);
  const ctx = canvas.getContext('2d');
  ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

  const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
  const pixels = imageData.data;
  const colorMap = {};

  // Sample pixels and quantize
  for (let i = 0; i < pixels.length; i += 4) {
    const r = Math.round(pixels[i] / 16) * 16;
    const g = Math.round(pixels[i+1] / 16) * 16;
    const b = Math.round(pixels[i+2] / 16) * 16;
    const key = `${r},${g},${b}`;
    colorMap[key] = (colorMap[key] || 0) + 1;
  }

  // Sort by frequency
  const sorted = Object.entries(colorMap)
    .map(([k, count]) => {
      const [r,g,b] = k.split(',').map(Number);
      return { r, g, b, count };
    })
    .sort((a, b) => b.count - a.count);

  // Merge similar colors
  const merged = [];
  for (const c of sorted) {
    let found = false;
    for (const m of merged) {
      if (colorDist(c, m) < 40) {
        m.r = Math.round((m.r * m.count + c.r * c.count) / (m.count + c.count));
        m.g = Math.round((m.g * m.count + c.g * c.count) / (m.count + c.count));
        m.b = Math.round((m.b * m.count + c.b * c.count) / (m.count + c.count));
        m.count += c.count;
        found = true;
        break;
      }
    }
    if (!found) merged.push({...c});
  }

  // Sort by saturation + brightness (more vivid first)
  merged.sort((a, b) => {
    const sa = getHSL(a).s + getHSL(a).l;
    const sb = getHSL(b).s + getHSL(b).l;
    return sb - sa;
  });

  currentColors = merged.slice(0, 20);
  renderSwatches();
}

function colorDist(a, b) {
  return Math.sqrt((a.r-b.r)**2 + (a.g-b.g)**2 + (a.b-b.b)**2);
}

function getHSL(c) {
  let r = c.r/255, g = c.g/255, b = c.b/255;
  const max = Math.max(r,g,b), min = Math.min(r,g,b);
  let h, s, l = (max+min)/2;
  if (max === min) { h = s = 0; }
  else {
    const d = max - min;
    s = l > 0.5 ? d / (2-max-min) : d / (max+min);
    switch (max) {
      case r: h = ((g-b)/d + (g<b?6:0)) / 6; break;
      case g: h = ((b-r)/d + 2) / 6; break;
      case b: h = ((r-g)/d + 4) / 6; break;
    }
  }
  return { h: Math.round(h*360), s: Math.round(s*100), l: Math.round(l*100) };
}

function setColors(n) {
  colorCount = n;
  document.getElementById('color-count').textContent = n;
  renderSwatches();
}

function renderSwatches() {
  const container = document.getElementById('color-swatches');
  const colors = currentColors.slice(0, colorCount);
  let html = '';

  // Sort by hue for nice display
  const withHue = colors.map(c => ({...c, hsl: getHSL(c)}));
  withHue.sort((a, b) => a.hsl.h - b.hsl.h);

  // Build a harmonious palette: pick evenly spaced hues
  for (const c of withHue) {
    const hex = rgbToHex(c.r, c.g, c.b);
    const hsl = c.hsl;
    const textColor = hsl.l > 55 ? '#1f2937' : '#ffffff';
    html += `
      <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-gray-50 cursor-pointer group" onclick="copyColor('${hex}')">
        <div class="w-10 h-10 rounded-lg border border-gray-200 shrink-0" style="background:${hex}"></div>
        <span class="font-mono text-sm text-gray-700 group-hover:text-blue-600">${hex}</span>
        <span class="text-xs text-gray-400">hsl(${hsl.h}, ${hsl.s}%, ${hsl.l}%)</span>
        <span class="ml-auto text-xs text-gray-300 opacity-0 group-hover:opacity-100">点击复制</span>
      </div>`;
  }

  container.innerHTML = html;
}

function rgbToHex(r, g, b) {
  return '#' + [r,g,b].map(v => Math.round(v).toString(16).padStart(2,'0')).join('').toUpperCase();
}

function copyColor(hex) {
  navigator.clipboard.writeText(hex);
}

function exportPalette() {
  const colors = currentColors.slice(0, colorCount);
  const withHue = colors.map(c => ({...c, hsl: getHSL(c)}));
  withHue.sort((a, b) => a.hsl.h - b.hsl.h);

  let text = '/* Palette extracted from image */\n';
  withHue.forEach((c, i) => {
    const hex = rgbToHex(c.r, c.g, c.b);
    text += `--color-${i+1}: ${hex};\n`;
  });
  text += '\n/* HEX */\n';
  text += withHue.map(c => rgbToHex(c.r, c.g, c.b)).join(', ');

  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('[onclick^="exportPalette"]');
    btn.textContent = '✅ 已导出';
    setTimeout(() => btn.textContent = '📋 导出', 1500);
  })
      .catch(function(err) { console.error(err); });;
}
</script>
