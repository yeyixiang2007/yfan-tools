<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="flex flex-wrap gap-2 mb-4">
        <button onclick="mergePdfs()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">📎 合并</button>
        <button onclick="splitPdf()" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 text-sm font-medium">✂️ 拆分</button>
        <button onclick="extractPages()" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 text-sm font-medium">📄 提取页面</button>
        <button onclick="clearAll()" class="px-4 py-2 bg-white border border-gray-300 text-gray-500 rounded-lg hover:bg-gray-50 text-sm font-medium">清空</button>
      </div>

      <div id="pdf-upload-area" class="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:border-blue-400 transition cursor-pointer" onclick="document.getElementById('pdf-input').click()">
        <div class="text-4xl mb-2">📄</div>
        <p class="text-gray-500 mb-1">上传 PDF 文件</p>
        <p class="text-xs text-gray-400">支持多个文件（合并模式）或单个文件（拆分/提取）</p>
        <input id="pdf-input" type="file" accept=".pdf" multiple class="hidden" onchange="loadPdfs(event)">
      </div>

      <div id="pdf-list-area" class="hidden mt-4">
        <div class="mb-3">
          <h3 class="text-sm font-medium text-gray-700 mb-2">📂 已加载的文件</h3>
          <div id="file-list" class="space-y-2"></div>
        </div>

        <div id="merge-options" class="hidden mb-3 p-4 bg-gray-50 rounded-lg">
          <label class="text-sm font-medium text-gray-700">合并后文件名</label>
          <div class="flex gap-2 mt-1">
            <input id="output-name" type="text" value="merged.pdf" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono">
            <button onclick="downloadPdf()" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-sm font-medium">⬇️ 下载</button>
          </div>
        </div>

        <div id="split-options" class="hidden mb-3 p-4 bg-gray-50 rounded-lg">
          <div class="flex items-center gap-3 mb-2">
            <label class="text-sm text-gray-700">提取范围</label>
            <input id="page-range" type="text" value="1" placeholder="1-5, 7, 9-12" class="w-48 px-3 py-2 border border-gray-300 rounded-lg text-sm">
            <span class="text-xs text-gray-400">(例: 1-5, 7, 9-12)</span>
          </div>
          <div class="flex gap-2">
            <span class="text-xs text-gray-500 self-center">共 <span id="total-pages">0</span> 页</span>
            <span class="text-xs text-gray-500 self-center">/</span>
            <span class="text-xs text-gray-500 self-center">每页拆一份</span>
            <button onclick="splitAllPages()" class="px-3 py-1.5 bg-indigo-100 text-indigo-700 rounded text-xs hover:bg-indigo-200">全部拆开</button>
          </div>
        </div>

        <div id="pdf-preview" class="hidden mt-3">
          <canvas id="pdf-canvas" class="w-full border border-gray-200 rounded-lg"></canvas>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf-lib/1.17.1/pdf-lib.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>

<script>
pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

let loadedFiles = [];
let loadedPdfDocs = [];

function loadPdfs(e) {
  const files = Array.from(e.target.files);
  if (files.length === 0) return;

  loadedFiles = files;
  document.getElementById('pdf-upload-area').classList.add('hidden');
  document.getElementById('pdf-list-area').classList.remove('hidden');

  renderFileList();
  updateOptions();
}

function renderFileList() {
  const container = document.getElementById('file-list');
  container.innerHTML = loadedFiles.map((f, i) =>
    `<div class="flex items-center gap-3 p-3 bg-white border border-gray-200 rounded-lg">
      <span class="text-xl">📄</span>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-gray-700 truncate">${f.name}</p>
        <p class="text-xs text-gray-400">${(f.size / 1024).toFixed(1)} KB</p>
      </div>
      <button onclick="removeFile(${i})" class="text-gray-400 hover:text-red-500 text-sm">✕</button>
    </div>`
  ).join('');
}

function removeFile(idx) {
  loadedFiles.splice(idx, 1);
  if (loadedFiles.length === 0) {
    document.getElementById('pdf-upload-area').classList.remove('hidden');
    document.getElementById('pdf-list-area').classList.add('hidden');
    return;
  }
  renderFileList();
  updateOptions();
}

function updateOptions() {
  document.getElementById('merge-options').classList.toggle('hidden', loadedFiles.length < 2);
  document.getElementById('split-options').classList.toggle('hidden', loadedFiles.length !== 1);
  if (loadedFiles.length === 1) previewPdf(loadedFiles[0]);
}

async function previewPdf(file) {
  try {
    const data = await file.arrayBuffer();
    const pdf = await pdfjsLib.getDocument({data}).promise;
    const page = await pdf.getPage(1);
    const viewport = page.getViewport({scale: 0.5});
    const canvas = document.getElementById('pdf-canvas');
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    const ctx = canvas.getContext('2d');
    await page.render({canvasContext: ctx, viewport}).promise;
    document.getElementById('pdf-preview').classList.remove('hidden');
    document.getElementById('total-pages').textContent = pdf.numPages;
  } catch(e) {
    document.getElementById('pdf-preview').classList.add('hidden');
  }
}

async function mergePdfs() {
  if (loadedFiles.length < 2) { alert('请上传至少 2 个 PDF 文件'); return; }
  const { PDFDocument } = PDFLib;
  const mergedPdf = await PDFDocument.create();

  for (const file of loadedFiles) {
    const data = await file.arrayBuffer();
    const pdf = await PDFDocument.load(data);
    const indices = pdf.getPageIndices();
    const pages = await mergedPdf.copyPages(pdf, indices);
    pages.forEach(p => mergedPdf.addPage(p));
  }

  const mergedBytes = await mergedPdf.save();
  const blob = new Blob([mergedBytes], {type: 'application/pdf'});
  const url = URL.createObjectURL(blob);

  const btn = document.querySelector('[onclick^="mergePdfs"]');
  btn.textContent = '✅ 合并完成';
  setTimeout(() => btn.textContent = '📎 合并', 2000);

  downloadBlob(blob, document.getElementById('output-name').value || 'merged.pdf');
}

async function splitPdf() {
  if (loadedFiles.length !== 1) { alert('请上传 1 个 PDF 文件'); return; }
  const range = document.getElementById('page-range').value.trim();
  if (!range) { alert('请输入页面范围'); return; }

  const pages = parseRange(range);
  if (!pages || pages.length === 0) { alert('页面范围无效'); return; }

  const { PDFDocument } = PDFLib;
  const data = await loadedFiles[0].arrayBuffer();
  const srcPdf = await PDFDocument.load(data);

  if (pages.some(p => p < 1 || p > srcPdf.getPageCount())) {
    alert('页面编号超出范围'); return;
  }

  const newPdf = await PDFDocument.create();
  const indices = pages.map(p => p - 1);
  const copied = await newPdf.copyPages(srcPdf, indices);
  copied.forEach(p => newPdf.addPage(p));

  const bytes = await newPdf.save();
  const blob = new Blob([bytes], {type: 'application/pdf'});
  downloadBlob(blob, `extracted_${loadedFiles[0].name}`);
}

async function splitAllPages() {
  if (loadedFiles.length !== 1) { alert('请上传 1 个 PDF 文件'); return; }
  const { PDFDocument } = PDFLib;
  const data = await loadedFiles[0].arrayBuffer();
  const srcPdf = await PDFDocument.load(data);
  const count = srcPdf.getPageCount();

  for (let i = 0; i < count; i++) {
    const newPdf = await PDFDocument.create();
    const [page] = await newPdf.copyPages(srcPdf, [i]);
    newPdf.addPage(page);
    const bytes = await newPdf.save();
    const blob = new Blob([bytes], {type: 'application/pdf'});
    downloadBlob(blob, `page_${i+1}_of_${loadedFiles[0].name}`);
  }
}

function extractPages() { splitPdf(); }

function parseRange(str) {
  const result = [];
  const parts = str.split(',');
  for (const part of parts) {
    const m = part.match(/(\d+)\s*-\s*(\d+)/);
    if (m) {
      for (let i = parseInt(m[1]); i <= parseInt(m[2]); i++) result.push(i);
    } else if (/^\d+$/.test(part.trim())) {
      result.push(parseInt(part.trim()));
    }
  }
  return result;
}

function downloadBlob(blob, name) {
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = name; a.click();
  URL.revokeObjectURL(url);
}

function downloadPdf() { mergePdfs(); }

function clearAll() {
  loadedFiles = [];
  document.getElementById('pdf-upload-area').classList.remove('hidden');
  document.getElementById('pdf-list-area').classList.add('hidden');
  document.getElementById('pdf-preview').classList.add('hidden');
  document.getElementById('file-list').innerHTML = '';
}
</script>
