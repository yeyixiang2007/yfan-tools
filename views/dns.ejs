<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-1">域名或记录</label>
        <div class="flex gap-2">
          <input id="dns-input" type="text" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" placeholder="例如: example.com" value="google.com" spellcheck="false">
          <button onclick="queryDns()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">🔍 查询</button>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 mb-4 text-sm">
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" class="dns-type" value="A" checked onchange="queryDns()"> A (IPv4)
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" class="dns-type" value="AAAA" onchange="queryDns()"> AAAA (IPv6)
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" class="dns-type" value="MX" checked onchange="queryDns()"> MX
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" class="dns-type" value="NS" onchange="queryDns()"> NS
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" class="dns-type" value="TXT" onchange="queryDns()"> TXT
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" class="dns-type" value="CNAME" onchange="queryDns()"> CNAME
        </label>
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" class="dns-type" value="SOA" onchange="queryDns()"> SOA
        </label>
      </div>

      <div id="dns-loading" class="hidden text-center py-8">
        <div class="animate-spin inline-block w-6 h-6 border-2 border-blue-600 border-t-transparent rounded-full"></div>
        <p class="text-sm text-gray-500 mt-2">正在查询...</p>
      </div>

      <div id="dns-results" class="hidden space-y-4"></div>
      <div id="dns-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-600"></div>
    </div>
  </div>
</div>

<script>
async function queryDns() {
  const domain = document.getElementById('dns-input').value.trim();
  if (!domain) { showDnsError('请输入域名'); return; }

  const types = [];
  document.querySelectorAll('.dns-type:checked').forEach(cb => types.push(cb.value));
  if (types.length === 0) { showDnsError('请至少选择一种记录类型'); return; }

  document.getElementById('dns-loading').classList.remove('hidden');
  document.getElementById('dns-results').classList.add('hidden');
  document.getElementById('dns-error').classList.add('hidden');

  try {
    const results = [];
    for (const type of types) {
      const resp = await fetch('https://dns.google/resolve?name=' + encodeURIComponent(domain) + '&type=' + type);
      const data = await resp.json();
      if (data.Answer && data.Answer.length > 0) {
        results.push({ type, records: data.Answer });
      } else {
        results.push({ type, records: [], empty: true });
      }
    }

    document.getElementById('dns-loading').classList.add('hidden');
    showDnsResults(results, domain);
  } catch (e) {
    document.getElementById('dns-loading').classList.add('hidden');
    showDnsError('查询失败: ' + e.message);
  }
}

function showDnsResults(results, domain) {
  const container = document.getElementById('dns-results');
  container.classList.remove('hidden');

  let html = `<div class="p-3 bg-blue-50 border border-blue-100 rounded-lg mb-3">
    <div class="text-xs text-gray-500">域名</div>
    <div class="text-sm font-mono font-bold text-gray-800">${escapeHtml(domain)}</div>
  </div>`;

  for (const r of results) {
    html += `<div class="p-3 bg-gray-50 border border-gray-100 rounded-lg">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-semibold text-gray-700">${r.type} 记录</span>
        <span class="text-xs text-gray-400">${r.empty ? '0 条' : r.records.length + ' 条'}</span>
      </div>`;

    if (r.empty) {
      html += '<p class="text-xs text-gray-400">无记录</p>';
    } else {
      for (const rec of r.records) {
        const ttl = rec.TTL > 86400 ? Math.floor(rec.TTL / 86400) + 'd' :
                    rec.TTL > 3600 ? Math.floor(rec.TTL / 3600) + 'h' :
                    rec.TTL > 60 ? Math.floor(rec.TTL / 60) + 'm' : rec.TTL + 's';
        html += `<div class="flex items-start gap-2 py-1 border-b border-gray-200 last:border-0">
          <span class="text-xs text-blue-500 font-mono mt-0.5">${ttl}</span>
          <span class="text-xs font-mono text-gray-700 break-all">${escapeHtml(rec.data)}</span>
        </div>`;
      }
    }
    html += '</div>';
  }

  container.innerHTML = html;
}

function showDnsError(msg) {
  document.getElementById('dns-error').textContent = '⚠️ ' + msg;
  document.getElementById('dns-error').classList.remove('hidden');
}

function escapeHtml(s) { return String(s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[m]); }
</script>
