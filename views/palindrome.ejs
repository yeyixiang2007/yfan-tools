<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="flex flex-wrap gap-2 mb-4">
        <button onclick="checkPalindrome()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">🔍 检测</button>
        <button onclick="clearAll()" class="px-4 py-2 bg-white border border-gray-300 text-gray-500 rounded-lg hover:bg-gray-50 text-sm font-medium">清空</button>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">输入文本</label>
        <textarea id="palindrome-input" rows="4" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" spellcheck="false" placeholder="输入文本..." oninput="autoCheck()">A man, a plan, a canal: Panama</textarea>
      </div>

      <div id="palindrome-result" class="hidden mb-4 p-6 rounded-lg text-center">
        <div id="palindrome-icon" class="text-4xl mb-2"></div>
        <div id="palindrome-status" class="text-lg font-bold"></div>
        <div id="palindrome-detail" class="text-sm text-gray-500 mt-1"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-4 bg-gray-50 rounded-lg">
          <h3 class="text-sm font-medium text-gray-700 mb-2">📖 什么是回文？</h3>
          <p class="text-xs text-gray-500">回文是指正读和反读都相同的文字序列，忽略空格、标点和大小写。</p>
          <div class="mt-2 text-xs text-gray-400">例如：上海自来水来自海上、level、racecar</div>
        </div>
        <div class="p-4 bg-gray-50 rounded-lg">
          <h3 class="text-sm font-medium text-gray-700 mb-2">💡 试试这些</h3>
          <div class="text-xs text-gray-500 space-y-1">
            <div class="cursor-pointer hover:text-blue-600" onclick="tryExample('racecar')">racecar</div>
            <div class="cursor-pointer hover:text-blue-600" onclick="tryExample('Was it a car or a cat I saw?')">Was it a car or a cat I saw?</div>
            <div class="cursor-pointer hover:text-blue-600" onclick="tryExample('Never odd or even')">Never odd or even</div>
            <div class="cursor-pointer hover:text-blue-600" onclick="tryExample('上海自来水来自海上')">上海自来水来自海上</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function autoCheck() { checkPalindrome(); }

function checkPalindrome() {
  const text = document.getElementById('palindrome-input').value;
  const resultDiv = document.getElementById('palindrome-result');
  const icon = document.getElementById('palindrome-icon');
  const status = document.getElementById('palindrome-status');
  const detail = document.getElementById('palindrome-detail');

  if (!text.trim()) { resultDiv.classList.add('hidden'); return; }

  const cleaned = text.replace(/[^a-zA-Z0-9\u4e00-\u9fff]/g, '').toLowerCase();
  const reversed = cleaned.split('').reverse().join('');
  const isPal = cleaned === reversed;

  resultDiv.classList.remove('hidden');
  resultDiv.className = isPal
    ? 'mb-4 p-6 rounded-lg text-center bg-green-50 border border-green-200'
    : 'mb-4 p-6 rounded-lg text-center bg-red-50 border border-red-200';

  icon.textContent = isPal ? '✅' : '❌';
  status.textContent = isPal ? '是回文！' : '不是回文';
  status.className = isPal ? 'text-lg font-bold text-green-700' : 'text-lg font-bold text-red-600';

  const length = cleaned.length;
  detail.textContent = `清理后: ${length} 个字符，${isPal ? '正反读一致' : '正反读不一致'}`;
}

function tryExample(text) {
  document.getElementById('palindrome-input').value = text;
  checkPalindrome();
}

function clearAll() {
  document.getElementById('palindrome-input').value = '';
  document.getElementById('palindrome-result').classList.add('hidden');
}
</script>
