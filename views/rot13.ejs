<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="flex flex-wrap gap-2 mb-4">
        <button onclick="rot13()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">ROT13</button>
        <button onclick="rotN()" class="px-4 py-2 bg-gray-800 text-white rounded-lg hover:bg-gray-900 text-sm font-medium">ROT-N</button>
        <button onclick="bruteForce()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">🔓 暴力破解 (1-25)</button>
        <button onclick="copyResult()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">📋 复制</button>
        <button onclick="clearAll()" class="px-4 py-2 bg-white border border-gray-300 text-gray-500 rounded-lg hover:bg-gray-50 text-sm font-medium">清空</button>
      </div>

      <div class="flex gap-4 mb-4 items-end">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">移位量 (ROT-N)</label>
          <input id="rot-n" type="number" min="1" max="25" value="13" class="w-20 px-3 py-2 border border-gray-300 rounded-lg text-center text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
        </div>
        <button onclick="rotN()" class="px-3 py-2 bg-blue-600 text-white rounded-lg text-sm">应用</button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">原文</label>
          <textarea id="rot-input" rows="6" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" placeholder="输入文本..." spellcheck="false">Hello World!</textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">加密/解密结果</label>
          <textarea id="rot-output" rows="6" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm bg-gray-50 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" readonly placeholder="结果..."></textarea>
        </div>
      </div>

      <div id="brute-results" class="hidden mt-4 p-4 bg-gray-50 rounded-lg">
        <h3 class="text-sm font-semibold text-gray-700 mb-2">🔓 所有移位结果</h3>
        <div id="brute-table" class="text-xs font-mono space-y-1 max-h-60 overflow-y-auto"></div>
      </div>
    </div>
  </div>
</div>

<script>
const inputEl = document.getElementById('rot-input');
const outputEl = document.getElementById('rot-output');

function rot13() {
  const text = inputEl.value;
  outputEl.value = rotShift(text, 13);
}

function rotN() {
  const n = parseInt(document.getElementById('rot-n').value) || 13;
  const text = inputEl.value;
  outputEl.value = rotShift(text, n);
}

function rotShift(text, n) {
  return text.split('').map(ch => {
    const code = ch.charCodeAt(0);
    if (code >= 65 && code <= 90) return String.fromCharCode(((code - 65 + n) % 26) + 65);
    if (code >= 97 && code <= 122) return String.fromCharCode(((code - 97 + n) % 26) + 97);
    return ch;
  }).join('');
}

function bruteForce() {
  const text = inputEl.value;
  if (!text) return;

  const resultsDiv = document.getElementById('brute-results');
  const tableDiv = document.getElementById('brute-table');

  let html = '';
  for (let i = 1; i <= 25; i++) {
    const shifted = rotShift(text, i);
    html += `<div class="flex gap-2"><span class="text-gray-400 w-12 shrink-0">ROT-${String(i).padStart(2)}</span><span>${escapeHtml(shifted)}</span></div>`;
  }

  tableDiv.innerHTML = html;
  resultsDiv.classList.remove('hidden');
}

function copyResult() {
  const text = outputEl.value;
  if (!text) return;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('[onclick="copyResult()"]');
    btn.textContent = '✅ 已复制';
    setTimeout(() => btn.textContent = '📋 复制', 1500);
  });
}

function clearAll() { inputEl.value = ''; outputEl.value = ''; document.getElementById('brute-results').classList.add('hidden'); }

function escapeHtml(s) { return String(s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[m]); }
</script>
