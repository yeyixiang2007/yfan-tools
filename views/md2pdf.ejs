| UUID 生成器 | 1.0 | 批量生成 |</textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">实时预览</label>
          <div id="md-preview" class="w-full min-h-[400px] border border-gray-300 rounded-lg p-4 bg-white overflow-auto prose prose-sm max-w-none"></div>
        </div>
      </div>

      <!-- Controls -->
      <div class="flex flex-wrap gap-2">
        <button onclick="exportPDF()" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">
          📄 导出 PDF (前端)
        </button>
        <button onclick="exportPDFBackend()" class="px-6 py-2 bg-gray-800 text-white rounded-lg hover:bg-gray-900 text-sm font-medium">
          🖨️ 导出 PDF (后端)
        </button>
        <button onclick="clearAll()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">清空</button>
      </div>
      <div id="md2pdf-status" class="mt-3 text-sm text-gray-500"></div>
    </div>
  </div>
</div>

<!-- marked for Markdown rendering -->
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<!-- html2pdf for PDF export -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<script>
// Configure marked
marked.setOptions({
  breaks: true,
  gfm: true
});

function renderPreview() {
  const input = document.getElementById('md-input').value;
  const preview = document.getElementById('md-preview');
  preview.innerHTML = marked.parse(input);
}

function exportPDF() {
  const preview = document.getElementById('md-preview');
  const btn = event.target;
  const origText = btn.textContent;

  btn.textContent = '⏳ 生成中...';
  btn.disabled = true;

  const opt = {
    margin:       10,
    filename:     'document.pdf',
    image:        { type: 'jpeg', quality: 0.98 },
    html2canvas:  { scale: 2, letterRendering: true },
    jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
  };

  html2pdf().set(opt).from(preview).save().then(() => {
    btn.textContent = origText;
    btn.disabled = false;
  }).catch(() => {
    btn.textContent = origText;
    btn.disabled = false;
  });
}

function clearAll() {
  document.getElementById('md-input').value = '';
  document.getElementById('md2pdf-status').textContent = '';
  renderPreview();
}

function exportPDFBackend() {
  const markdown = document.getElementById('md-input').value;
  const status = document.getElementById('md2pdf-status');

  if (!markdown.trim()) {
    status.textContent = '⚠️ 请输入 Markdown 内容';
    return;
  }

  status.textContent = '⏳ 后端生成中...';

  fetch('/md2pdf/render', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ markdown, margin: 10, fontSize: 11 })
  })
  .then(res => {
    if (!res.ok) throw new Error('生成失败');
    return res.blob();
  })
  .then(blob => {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'yfan-document.pdf';
    a.click();
    URL.revokeObjectURL(url);
    status.textContent = '✅ PDF 已下载';
  })
  .catch(err => {
    status.textContent = '❌ ' + err.message;
  });
}

// Render on load
renderPreview();
</script>
