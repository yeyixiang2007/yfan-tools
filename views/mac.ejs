<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-1">MAC 地址</label>
        <div class="flex gap-2">
          <input id="mac-input" type="text" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" placeholder="例如: 00:1A:2B:3C:4D:5E" spellcheck="false">
          <button onclick="lookupMac()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">🔍 查询</button>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 mb-4">
        <label class="flex items-center gap-1.5 text-sm text-gray-600 cursor-pointer">
          <input type="radio" name="mac-format" value=":" checked onchange="formatMac()"> 00:1A:2B
        </label>
        <label class="flex items-center gap-1.5 text-sm text-gray-600 cursor-pointer">
          <input type="radio" name="mac-format" value="-" onchange="formatMac()"> 00-1A-2B
        </label>
        <label class="flex items-center gap-1.5 text-sm text-gray-600 cursor-pointer">
          <input type="radio" name="mac-format" value="." onchange="formatMac()"> 001A.2B3C.4D5E
        </label>
        <label class="flex items-center gap-1.5 text-sm text-gray-600 cursor-pointer">
          <input type="radio" name="mac-format" value="plain" onchange="formatMac()"> 001A2B3C4D5E
        </label>
      </div>

      <div id="mac-result" class="hidden space-y-4"></div>
      <div id="mac-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-600"></div>
      <div id="mac-loading" class="hidden text-center py-8">
        <div class="animate-spin inline-block w-6 h-6 border-2 border-blue-600 border-t-transparent rounded-full"></div>
        <p class="text-sm text-gray-500 mt-2">正在查询...</p>
      </div>
    </div>
  </div>
</div>

<script>
async function lookupMac() {
  let mac = document.getElementById('mac-input').value.trim();
  if (!mac) { showMacError('请输入 MAC 地址'); return; }

  // Normalize
  mac = mac.replace(/[^0-9a-fA-F]/g, '').toUpperCase();
  if (mac.length !== 12) { showMacError('MAC 地址需要是12位十六进制字符'); return; }
  mac = mac.match(/.{2}/g).join(':');

  document.getElementById('mac-loading').classList.remove('hidden');
  document.getElementById('mac-result').classList.add('hidden');
  document.getElementById('mac-error').classList.add('hidden');

  try {
    const resp = await fetch('https://api.macvendors.com/' + mac);
    if (resp.status === 200) {
      const vendor = await resp.text();
      document.getElementById('mac-loading').classList.add('hidden');
      showMacResult(vendor, mac);
    } else if (resp.status === 404) {
      document.getElementById('mac-loading').classList.add('hidden');
      showMacError('未找到该 MAC 地址对应的厂商');
    } else {
      throw new Error('查询失败 (' + resp.status + ')');
    }
  } catch (e) {
    document.getElementById('mac-loading').classList.add('hidden');
    showMacError('查询失败: ' + e.message);
  }
}

function showMacResult(vendor, mac) {
  const resultDiv = document.getElementById('mac-result');
  resultDiv.classList.remove('hidden');
  resultDiv.innerHTML = `
    <div class="p-4 bg-blue-50 border border-blue-100 rounded-lg">
      <div class="text-xs text-gray-500 mb-1">MAC 地址</div>
      <div class="text-lg font-mono font-bold text-gray-800">${mac}</div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <div class="p-4 bg-gray-50 border border-gray-100 rounded-lg">
        <div class="text-xs text-gray-500 mb-1">厂商</div>
        <div class="text-sm font-medium text-gray-800">${escapeHtml(vendor)}</div>
      </div>
      <div class="p-4 bg-gray-50 border border-gray-100 rounded-lg">
        <div class="text-xs text-gray-500 mb-1">OUI</div>
        <div class="text-sm font-mono font-medium text-gray-800">${mac.substring(0, 8)}</div>
      </div>
      <div class="p-4 bg-gray-50 border border-gray-100 rounded-lg">
        <div class="text-xs text-gray-500 mb-1">组播</div>
        <div class="text-sm font-medium text-gray-800">${isMulticast(mac) ? '✅ 是' : '❌ 否'}</div>
      </div>
      <div class="p-4 bg-gray-50 border border-gray-100 rounded-lg">
        <div class="text-xs text-gray-500 mb-1">本地管理</div>
        <div class="text-sm font-medium text-gray-800">${isLocal(mac) ? '✅ 是' : '❌ 否'}</div>
      </div>
    </div>
  `;
}

function isMulticast(mac) {
  const first = parseInt(mac.substring(0, 2), 16);
  return (first & 1) === 1;
}

function isLocal(mac) {
  const first = parseInt(mac.substring(0, 2), 16);
  return (first & 2) === 2;
}

function formatMac() {
  const raw = document.getElementById('mac-input').value.replace(/[^0-9a-fA-F]/g, '');
  if (raw.length < 12) return;
  const pairs = raw.substring(0, 12).match(/.{2}/g);
  const format = document.querySelector('input[name="mac-format"]:checked').value;
  switch (format) {
    case ':': document.getElementById('mac-input').value = pairs.join(':'); break;
    case '-': document.getElementById('mac-input').value = pairs.join('-'); break;
    case '.': document.getElementById('mac-input').value = pairs.slice(0, 3).join('') + '.' + pairs.slice(3, 6).join(''); break;
    case 'plain': document.getElementById('mac-input').value = pairs.join(''); break;
  }
}

function showMacError(msg) {
  document.getElementById('mac-error').textContent = '⚠️ ' + msg;
  document.getElementById('mac-error').classList.remove('hidden');
}

function escapeHtml(s) { return String(s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[m]); }
</script>
