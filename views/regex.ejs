<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <!-- 正则表达式输入 -->
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">正则表达式</label>
        <div class="flex gap-2">
          <input id="regex-pattern" type="text" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" placeholder="例如: \d{3,5}" spellcheck="false">
          <select id="regex-flags" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 outline-none">
            <option value="g">全局 (g)</option>
            <option value="gi">全局+忽略大小写 (gi)</option>
            <option value="gm">全局+多行 (gm)</option>
            <option value="gim">全局+忽略大小写+多行 (gim)</option>
          </select>
        </div>
      </div>

      <!-- 测试文本 -->
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">测试文本</label>
        <textarea id="regex-text" rows="8" class="w-full px-4 py-3 border border-gray-300 rounded-lg font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none resize-y" placeholder="在此输入要匹配的测试文本&#10;例如: 我的电话是 13800138000，邮编 100086"></textarea>
      </div>

      <!-- 替换文本 -->
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">替换文本（可选）</label>
        <input id="regex-replace" type="text" class="w-full px-4 py-2 border border-gray-300 rounded-lg font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" placeholder="输入替换内容，留空则只做匹配" spellcheck="false">
      </div>

      <!-- 操作按钮 -->
      <div class="flex flex-wrap gap-2 mb-6">
        <button onclick="testMatch()" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">🔍 匹配</button>
        <button onclick="testReplace()" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 text-sm font-medium">✏️ 替换</button>
        <button onclick="clearRegex()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">清空</button>
      </div>

      <!-- 结果 -->
      <div id="regex-result" class="hidden">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-sm font-semibold text-gray-700">匹配结果</h3>
          <span id="regex-count" class="text-xs px-2 py-0.5 bg-blue-100 text-blue-700 rounded-full"></span>
        </div>
        <div id="regex-matches" class="space-y-2">
        </div>
        <div class="mt-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">高亮预览</label>
          <div id="regex-highlight" class="w-full min-h-[100px] px-4 py-3 border border-gray-200 rounded-lg bg-gray-50 font-mono text-sm whitespace-pre-wrap break-all leading-relaxed"></div>
        </div>
      </div>

      <!-- 快速参考 -->
      <div class="mt-8 p-4 bg-gray-50 rounded-lg">
        <h3 class="text-sm font-semibold text-gray-700 mb-2">📖 常用正则速查</h3>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-2 text-xs font-mono">
          <code class="bg-white px-2 py-1 rounded border border-gray-200">\d</code><span class="text-gray-500 text-xs">数字</span>
          <code class="bg-white px-2 py-1 rounded border border-gray-200">\w</code><span class="text-gray-500 text-xs">字母/数字/下划线</span>
          <code class="bg-white px-2 py-1 rounded border border-gray-200">\s</code><span class="text-gray-500 text-xs">空白字符</span>
          <code class="bg-white px-2 py-1 rounded border border-gray-200">.</code><span class="text-gray-500 text-xs">任意字符（除换行）</span>
          <code class="bg-white px-2 py-1 rounded border border-gray-200">*</code><span class="text-gray-500 text-xs">0次或多次</span>
          <code class="bg-white px-2 py-1 rounded border border-gray-200">+</code><span class="text-gray-500 text-xs">1次或多次</span>
          <code class="bg-white px-2 py-1 rounded border border-gray-200">?</code><span class="text-gray-500 text-xs">0次或1次</span>
          <code class="bg-white px-2 py-1 rounded border border-gray-200">{n,m}</code><span class="text-gray-500 text-xs">n到m次</span>
          <code class="bg-white px-2 py-1 rounded border border-gray-200">|</code><span class="text-gray-500 text-xs">或</span>
          <code class="bg-white px-2 py-1 rounded border border-gray-200">^</code><span class="text-gray-500 text-xs">行首</span>
          <code class="bg-white px-2 py-1 rounded border border-gray-200">$</code><span class="text-gray-500 text-xs">行尾</span>
          <code class="bg-white px-2 py-1 rounded border border-gray-200">( )</code><span class="text-gray-500 text-xs">捕获组</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function getPattern() {
  const pattern = document.getElementById('regex-pattern').value;
  if (!pattern) throw new Error('请输入正则表达式');
  const flags = document.getElementById('regex-flags').value;
  return new RegExp(pattern, flags);
}

function testMatch() {
  const text = document.getElementById('regex-text').value;
  const resultDiv = document.getElementById('regex-result');
  const matchesDiv = document.getElementById('regex-matches');
  const countSpan = document.getElementById('regex-count');
  const highlightDiv = document.getElementById('regex-highlight');

  try {
    const regex = getPattern();
    if (!text.trim()) throw new Error('请输入测试文本');

    resultDiv.classList.remove('hidden');

    // 查找所有匹配
    const matches = [];
    regex.lastIndex = 0;
    let match;
    while ((match = regex.exec(text)) !== null) {
      matches.push({
        full: match[0],
        index: match.index,
        groups: match.slice(1)
      });
      if (!regex.global) break;
    }

    // 显示数量
    countSpan.textContent = matches.length + ' 个匹配';

    if (matches.length === 0) {
      matchesDiv.innerHTML = '<p class="text-gray-400 text-sm py-4 text-center">没有找到匹配</p>';
      highlightDiv.innerHTML = text;
      return;
    }

    // 显示匹配列表
    matchesDiv.innerHTML = matches.map((m, i) => {
      let groupInfo = '';
      if (m.groups.length > 0) {
        groupInfo = '<div class="text-xs text-gray-400 mt-1">捕获组: ' +
          m.groups.map((g, j) => `$${j+1} = <strong class="text-green-600">${escapeHtml(g || '(空)')}</strong>`).join(', ') +
          '</div>';
      }
      return '<div class="p-2 bg-green-50 border border-green-200 rounded text-sm">' +
        '<span class="text-gray-400 mr-2">#' + (i+1) + '</span>' +
        '<span class="font-mono text-green-700">' + escapeHtml(m.full) + '</span>' +
        '<span class="text-gray-400 text-xs ml-2">(位置 ' + m.index + ')</span>' +
        groupInfo +
        '</div>';
    }).join('');

    // 高亮显示
    let lastEnd = 0;
    const parts = [];
    matches.forEach(m => {
      // 匹配前的文本
      if (m.index > lastEnd) {
        parts.push(escapeHtml(text.slice(lastEnd, m.index)));
      }
      parts.push('<mark class="bg-yellow-300 px-0.5 rounded">' + escapeHtml(m.full) + '</mark>');
      lastEnd = m.index + m.full.length;
    });
    if (lastEnd < text.length) {
      parts.push(escapeHtml(text.slice(lastEnd)));
    }
    highlightDiv.innerHTML = parts.join('');

  } catch (e) {
    resultDiv.classList.remove('hidden');
    matchesDiv.innerHTML = '<p class="text-red-500 text-sm">⚠️ ' + escapeHtml(e.message) + '</p>';
    countSpan.textContent = '';
    highlightDiv.innerHTML = '';
  }
}

function testReplace() {
  const text = document.getElementById('regex-text').value;
  const replaceStr = document.getElementById('regex-replace').value;
  const resultDiv = document.getElementById('regex-result');
  const matchesDiv = document.getElementById('regex-matches');
  const countSpan = document.getElementById('regex-count');
  const highlightDiv = document.getElementById('regex-highlight');

  try {
    const regex = getPattern();
    if (!text.trim()) throw new Error('请输入测试文本');
    if (!replaceStr.trim()) throw new Error('请输入替换文本');

    const result = text.replace(regex, replaceStr);

    resultDiv.classList.remove('hidden');
    countSpan.textContent = '替换完成';

    // 显示原始 vs 替换后
    matchesDiv.innerHTML = '<div class="p-3 bg-gray-50 border border-gray-200 rounded">' +
      '<div class="text-xs text-gray-500 mb-1">替换前:</div>' +
      '<div class="font-mono text-sm whitespace-pre-wrap">' + escapeHtml(text) + '</div>' +
      '<div class="text-xs text-gray-500 mt-3 mb-1">替换后:</div>' +
      '<div class="font-mono text-sm whitespace-pre-wrap text-green-700">' + escapeHtml(result) + '</div>' +
      '</div>';

    highlightDiv.innerHTML = escapeHtml(result);
  } catch (e) {
    resultDiv.classList.remove('hidden');
    matchesDiv.innerHTML = '<p class="text-red-500 text-sm">⚠️ ' + escapeHtml(e.message) + '</p>';
    countSpan.textContent = '';
    highlightDiv.innerHTML = '';
  }
}

function clearRegex() {
  document.getElementById('regex-pattern').value = '';
  document.getElementById('regex-text').value = '';
  document.getElementById('regex-replace').value = '';
  document.getElementById('regex-result').classList.add('hidden');
}

function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, function(m) {
    return {'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'}[m];
  });
}
</script>
