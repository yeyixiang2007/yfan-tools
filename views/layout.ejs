<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/static/css/app.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🐙</text></svg>">
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">
  <nav class="bg-white shadow-sm border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center gap-4">
      <a href="/" class="text-xl font-bold text-gray-800 hover:text-blue-600 transition shrink-0">🐙 yfan.tools</a>

      <!-- 全局搜索框 -->
      <div class="flex-1 max-w-md relative">
        <input id="nav-search" type="text"
               class="w-full pl-9 pr-3 py-1.5 text-sm border border-gray-200 rounded-lg
                      bg-gray-50 focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                      outline-none transition placeholder:text-gray-400"
               placeholder="搜索工具..."
               autocomplete="off"
               onfocus="initSearch()"
               oninput="searchTools(this.value)">
        <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>

        <!-- 搜索下拉 -->
        <div id="search-dropdown" class="hidden absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-lg shadow-lg z-50 max-h-80 overflow-y-auto"></div>
      </div>

      <span class="text-sm text-gray-400 hidden sm:inline">小工具集合</span>
    </div>
  </nav>

<script>
// ── 全局搜索（通过 API 加载）───
var searchToolsData = [];
var dropdown = document.getElementById('search-dropdown');

// 服务端注入数据（layout.ejs 渲染时 tools 变量已注入）
<% if (typeof tools !== 'undefined' && tools && tools.length > 0) { %>
searchToolsData = [
  <% tools.forEach(function(t, i) { %>
    { id: '<%- t.id %>', name: '<%- t.name.replace(/'/g, "\\'").replace(/</g, "&lt;").replace(/>/g, "&gt;") %>', desc: '<%- t.desc.replace(/'/g, "\\'").replace(/</g, "&lt;").replace(/>/g, "&gt;") %>', icon: '<%- t.icon %>' }<%= i < tools.length - 1 ? ',' : '' %>
  <% }) %>
];
<% } %>

function initSearch() {
  // 如果服务端未注入，从 API 动态加载
  if (!searchToolsData || searchToolsData.length === 0) {
    fetch('/api/tools')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        searchToolsData = data;
      })
      .catch(function() {});
  }
}

function searchTools(query) {
  query = query.toLowerCase().trim();

  if (!query) {
    dropdown.classList.add('hidden');
    return;
  }

  var results = searchToolsData.filter(function(t) {
    return t.name.toLowerCase().includes(query) ||
           t.desc.toLowerCase().includes(query);
  });

  if (results.length === 0) {
    dropdown.innerHTML = '<div class="px-4 py-6 text-center text-sm text-gray-400">🔍 没有匹配的工具</div>';
    dropdown.classList.remove('hidden');
    return;
  }

  dropdown.innerHTML = results.map(function(t) {
    return '<a href="/' + t.id + '" class="flex items-center gap-3 px-4 py-2.5 hover:bg-blue-50 transition border-b border-gray-100 last:border-0 group">' +
           '<span class="text-xl">' + t.icon + '</span>' +
           '<div class="flex-1 min-w-0">' +
           '<div class="text-sm font-medium text-gray-800 group-hover:text-blue-600">' + highlightMatch(t.name, query) + '</div>' +
           '<div class="text-xs text-gray-400 truncate">' + highlightMatch(t.desc, query) + '</div>' +
           '</div>' +
           '<span class="text-xs text-blue-500 opacity-0 group-hover:opacity-100 transition">→</span>' +
           '</a>';
  }).join('');

  dropdown.classList.remove('hidden');
}

function highlightMatch(text, query) {
  if (!query) return text;
  var idx = text.toLowerCase().indexOf(query);
  if (idx === -1) return text;
  return text.substring(0, idx) +
         '<mark class="bg-yellow-200 text-gray-900 rounded px-0.5">' +
         text.substring(idx, idx + query.length) +
         '</mark>' +
         text.substring(idx + query.length);
}

// 点击外部关闭下拉
var searchInput = document.getElementById('nav-search');
document.addEventListener('click', function(e) {
  if (dropdown && !e.target.closest('#nav-search') && !e.target.closest('#search-dropdown')) {
    dropdown.classList.add('hidden');
  }
});

// 键盘导航
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    if (dropdown) dropdown.classList.add('hidden');
    if (searchInput) searchInput.blur();
  }
  // Ctrl/Cmd + K 聚焦搜索
  if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
    e.preventDefault();
    if (searchInput) { searchInput.focus(); searchInput.select(); }
  }
});
</script>

  <main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
    <%- content %>
  </main>

  <footer class="bg-white border-t border-gray-200 py-6 mt-8">
    <div class="max-w-4xl mx-auto px-4 text-center text-sm text-gray-400">
      <p>yfan.tools &copy; <%= new Date().getFullYear() %> &mdash; 用🐙做小工具</p>
    </div>
  </footer>
</body>
</html>
