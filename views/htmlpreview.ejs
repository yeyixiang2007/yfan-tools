<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="flex flex-wrap gap-2 mb-4">
        <button onclick="renderPreview()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">▶ 渲染</button>
        <button onclick="copyResult()" class="px-4 py-2 bg-gray-800 text-white rounded-lg hover:bg-gray-900 text-sm font-medium">📋 复制 HTML</button>
        <button onclick="downloadHtml()" class="px-4 py-2 bg-gray-700 text-white rounded-lg hover:bg-gray-800 text-sm font-medium">💾 下载</button>
        <button onclick="clearAll()" class="px-4 py-2 bg-white border border-gray-300 text-gray-500 rounded-lg hover:bg-gray-50 text-sm font-medium">清空</button>
      </div>

      <div class="grid grid-cols-1 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">HTML 源码</label>
          <textarea id="html-src" rows="8" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" spellcheck="false"><!DOCTYPE html>
<html>
<head><title>Demo</title><style>body{font-family:sans-serif;padding:20px}h1{color:#2563eb}</style></head>
<body>
  <h1>Hello World</h1>
  <p>This is a <strong>live preview</strong> of HTML content.</p>
  <ul>
    <li>Item 1</li>
    <li>Item 2</li>
    <li>Item 3</li>
  </ul>
  <button onclick="alert('Hi!')" style="padding:8px 16px;background:#3b82f6;color:white;border:none;border-radius:6px;cursor:pointer">Click Me</button>
</body>
</html></textarea>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">实时预览</label>
        <iframe id="html-preview" class="w-full border border-gray-300 rounded-lg bg-white min-h-[300px]"></iframe>
      </div>

      <div id="html-status" class="mt-2 text-xs text-gray-500"></div>
    </div>
  </div>
</div>

<script>
const srcEl = document.getElementById('html-src');

function renderPreview() {
  const html = srcEl.value;
  const iframe = document.getElementById('html-preview');
  iframe.srcdoc = html;
  document.getElementById('html-status').textContent = `HTML: ${html.length.toLocaleString()} 字符`;
}

function copyResult() {
  const text = srcEl.value;
  if (!text) return;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('[onclick="copyResult()"]');
    btn.textContent = '✅ 已复制';
    setTimeout(() => btn.textContent = '📋 复制 HTML', 1500);
  });
}

function downloadHtml() {
  const text = srcEl.value;
  if (!text) return;
  const blob = new Blob([text], { type: 'text/html' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'preview.html';
  a.click();
  URL.revokeObjectURL(a.href);
}

function clearAll() {
  srcEl.value = '';
  document.getElementById('html-preview').srcdoc = '';
  document.getElementById('html-status').textContent = '';
}

// Auto-render on load
renderPreview();
</script>
