<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">原始文本（左侧）</label>
          <textarea id="diff-left" rows="14" class="w-full px-4 py-3 border border-gray-300 rounded-lg font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none resize-y" placeholder="粘贴原始文本或代码..." spellcheck="false"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">修改后文本（右侧）</label>
          <textarea id="diff-right" rows="14" class="w-full px-4 py-3 border border-gray-300 rounded-lg font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none resize-y" placeholder="粘贴修改后的文本或代码..." spellcheck="false"></textarea>
        </div>
      </div>

      <div class="flex flex-wrap gap-2 mb-6">
        <button onclick="computeDiff()" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">🔄 对比</button>
        <button onclick="swapSides()" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 text-sm font-medium">⇄ 交换</button>
        <button onclick="clearDiff()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">清空</button>
      </div>

      <!-- 统计 -->
      <div id="diff-stats" class="hidden mb-4 flex gap-3 text-sm">
        <span id="diff-additions" class="px-2 py-1 bg-green-100 text-green-700 rounded">+0</span>
        <span id="diff-deletions" class="px-2 py-1 bg-red-100 text-red-700 rounded">-0</span>
        <span id="diff-changes" class="px-2 py-1 bg-gray-100 text-gray-600 rounded">修改 0 处</span>
      </div>

      <!-- Diff 结果 -->
      <div id="diff-result" class="hidden border border-gray-200 rounded-lg overflow-hidden">
        <div class="bg-gray-100 px-4 py-2 flex items-center justify-between border-b border-gray-200">
          <div class="flex items-center gap-2 text-xs text-gray-500">
            <span class="inline-block w-3 h-3 bg-green-400 rounded"></span><span>新增</span>
            <span class="inline-block w-3 h-3 bg-red-400 rounded"></span><span>删除</span>
            <span class="inline-block w-3 h-3 bg-orange-200 rounded"></span><span>修改</span>
          </div>
          <button onclick="copyDiff()" class="text-xs px-2 py-1 bg-white border border-gray-300 rounded hover:bg-gray-50">📋 复制 Diff</button>
        </div>
        <div id="diff-output" class="overflow-x-auto font-mono text-sm leading-6"></div>
      </div>
    </div>
  </div>
</div>

<script>
function computeDiff() {
  const left = document.getElementById('diff-left').value;
  const right = document.getElementById('diff-right').value;
  const resultDiv = document.getElementById('diff-result');
  const outputDiv = document.getElementById('diff-output');
  const statsDiv = document.getElementById('diff-stats');

  if (!left && !right) {
    return;
  }

  resultDiv.classList.remove('hidden');
  statsDiv.classList.remove('hidden');

  const leftLines = left.split('\n');
  const rightLines = right.split('\n');

  // LCS-based diff
  const diff = buildDiff(leftLines, rightLines);

  // 统计
  let additions = 0, deletions = 0, changes = 0;
  diff.forEach(part => {
    if (part.type === 'add') additions++;
    else if (part.type === 'del') deletions++;
    else if (part.type === 'change') changes++;
  });

  document.getElementById('diff-additions').textContent = '+' + additions;
  document.getElementById('diff-deletions').textContent = '-' + deletions;
  document.getElementById('diff-changes').textContent = '修改 ' + (changes) + ' 处';

  // 渲染
  let html = '<table class="w-full border-collapse">';
  let lineNum = 0;

  diff.forEach(part => {
    if (part.type === 'same') {
      part.lines.forEach(line => {
        lineNum++;
        html += '<tr class="hover:bg-gray-50">' +
          '<td class="text-right text-gray-400 text-xs px-2 py-0 select-none w-10 border-r border-gray-200 align-top">' + lineNum + '</td>' +
          '<td class="px-4 py-0 whitespace-pre-wrap">' + escapeHtml(line) + '</td>' +
          '</tr>';
      });
    } else if (part.type === 'del') {
      part.lines.forEach(line => {
        html += '<tr class="bg-red-50">' +
          '<td class="text-right text-red-400 text-xs px-2 py-0 select-none w-10 border-r border-red-200 align-top bg-red-100">' +
          '<span class="text-red-500">−</span></td>' +
          '<td class="px-4 py-0 whitespace-pre-wrap text-red-800 bg-red-50">' + escapeHtml(line) + '</td>' +
          '</tr>';
        deletions++;
      });
    } else if (part.type === 'add') {
      part.lines.forEach(line => {
        html += '<tr class="bg-green-50">' +
          '<td class="text-right text-green-400 text-xs px-2 py-0 select-none w-10 border-r border-green-200 align-top bg-green-100">' +
          '<span class="text-green-500">+</span></td>' +
          '<td class="px-4 py-0 whitespace-pre-wrap text-green-800 bg-green-50">' + escapeHtml(line) + '</td>' +
          '</tr>';
        additions++;
      });
    } else if (part.type === 'change') {
      // 显示旧行
      part.oldLines.forEach(line => {
        html += '<tr class="bg-red-50">' +
          '<td class="text-right text-orange-400 text-xs px-2 py-0 select-none w-10 border-r border-orange-200 align-top bg-orange-100">' +
          '<span class="text-orange-500">~</span></td>' +
          '<td class="px-4 py-0 whitespace-pre-wrap text-red-800 bg-red-50">' + escapeHtml(line) + '</td>' +
          '</tr>';
      });
      // 显示新行
      part.newLines.forEach(line => {
        html += '<tr class="bg-green-50">' +
          '<td class="text-right text-orange-400 text-xs px-2 py-0 select-none w-10 border-r border-orange-200 align-top bg-orange-100">' +
          '<span class="text-orange-500">~</span></td>' +
          '<td class="px-4 py-0 whitespace-pre-wrap text-green-800 bg-green-50">' + escapeHtml(line) + '</td>' +
          '</tr>';
      });
    }
  });

  html += '</table>';
  outputDiv.innerHTML = html;
}

function buildDiff(left, right) {
  // Myers diff 简化版 — LCS-based
  const m = left.length, n = right.length;

  // 计算 LCS 表
  const dp = Array.from({length: m + 1}, () => Array(n + 1).fill(0));
  for (let i = 1; i <= m; i++) {
    for (let j = 1; j <= n; j++) {
      if (left[i - 1] === right[j - 1]) {
        dp[i][j] = dp[i - 1][j - 1] + 1;
      } else {
        dp[i][j] = Math.max(dp[i - 1][j], dp[i][j - 1]);
      }
    }
  }

  // 回溯构建 diff
  const result = [];
  let i = m, j = n;
  const ops = [];

  while (i > 0 || j > 0) {
    if (i > 0 && j > 0 && left[i - 1] === right[j - 1]) {
      ops.push({ type: 'same', line: left[i - 1] });
      i--; j--;
    } else if (j > 0 && (i === 0 || dp[i][j - 1] >= dp[i - 1][j])) {
      ops.push({ type: 'add', line: right[j - 1] });
      j--;
    } else {
      ops.push({ type: 'del', line: left[i - 1] });
      i--;
    }
  }

  ops.reverse();

  // 合并连续相同类型
  const merged = [];
  let current = null;

  ops.forEach(op => {
    if (!current || current.type !== op.type) {
      if (current) merged.push(current);
      if (op.type === 'same') {
        current = { type: 'same', lines: [op.line] };
      } else if (op.type === 'add') {
        current = { type: 'add', lines: [op.line] };
      } else {
        current = { type: 'del', lines: [op.line] };
      }
    } else {
      current.lines.push(op.line);
    }
  });
  if (current) merged.push(current);

  // 将相邻的 del + add 合并为 change
  final = [];
  for (let k = 0; k < merged.length; k++) {
    const cur = merged[k];
    const next = merged[k + 1];

    if (cur.type === 'del' && next && next.type === 'add') {
      final.push({
        type: 'change',
        oldLines: cur.lines,
        newLines: next.lines
      });
      k++; // 跳过下一个
    } else {
      final.push(cur);
    }
  }

  return final;
}

function swapSides() {
  const left = document.getElementById('diff-left');
  const right = document.getElementById('diff-right');
  const tmp = left.value;
  left.value = right.value;
  right.value = tmp;
  computeDiff();
}

function clearDiff() {
  document.getElementById('diff-left').value = '';
  document.getElementById('diff-right').value = '';
  document.getElementById('diff-result').classList.add('hidden');
  document.getElementById('diff-stats').classList.add('hidden');
}

function copyDiff() {
  const outputDiv = document.getElementById('diff-output');
  const text = outputDiv.textContent;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('#diff-result .flex button');
    const orig = btn.textContent;
    btn.textContent = '✅ 已复制';
    setTimeout(() => { btn.textContent = orig; }, 2000);
  });
}

function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, function(m) {
    return {'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'}[m];
  });
}
</script>
