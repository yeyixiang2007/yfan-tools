  { e: '😤', n: ' face with steam from nose', c: 'smileys', k: 'angry frustrated triumph' },
  { e: '😡', n: ' pouting face', c: 'smileys', k: 'angry mad rage' },
  { e: '🥳', n: ' partying face', c: 'smileys', k: 'party celebrate birthday' },
