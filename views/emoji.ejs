  { e: '⚽', n: ' soccer ball', c: 'activities', k: 'soccer football sport' },
  { e: '🏀', n: ' basketball', c: 'activities', k: 'basketball sport' },
  { e: '🎵', n: ' musical note', c: 'activities', k: 'music note song' },
  { e: '🎮', n: ' video game', c: 'activities', k: 'game controller play' },
  { e: '🎬', n: ' clapper board', c: 'activities', k: 'movie film cinema' },
  { e: '💡', n: ' light bulb', c: 'objects', k: 'bulb idea light' },
