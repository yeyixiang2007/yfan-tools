  { e: '💪', n: ' flexed biceps', c: 'people', k: 'muscle strong flex' },
  { e: '👏', n: ' clapping hands', c: 'people', k: 'clap applause congratulate' },
  { e: '🤝', n: ' handshake', c: 'people', k: 'handshake deal agree' },
  { e: '❤️', n: ' red heart', c: 'smileys', k: 'heart love' },
  { e: '🔥', n: ' fire', c: 'nature', k: 'fire flame hot burn' },
  { e: '⭐', n: ' star', c: 'nature', k: 'star' },
  { e: '🌈', n: ' rainbow', c: 'nature', k: 'rainbow pride' },
  { e: '☀️', n: ' sun', c: 'nature', k: 'sun sunny weather' },
  { e: '🌙', n: ' moon', c: 'nature', k: 'moon night' },
  { e: '🌸', n: ' cherry blossom', c: 'nature', k: 'cherry blossom flower spring' },
  { e: '🌺', n: ' hibiscus', c: 'nature', k: 'hibiscus flower tropical' },
  { e: '🌲', n: ' evergreen tree', c: 'nature', k: 'tree evergreen pine' },
  { e: '🍕', n: ' pizza', c: 'food', k: 'pizza italian food' },
  { e: '🍔', n: ' hamburger', c: 'food', k: 'burger fast food' },
