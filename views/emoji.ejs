<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="mb-4">
        <input id="emoji-search" type="text" class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" placeholder="搜索 Emoji（中文/英文）..." oninput="searchEmoji()" autofocus>
      </div>

      <div class="flex flex-wrap gap-4 mb-4 text-sm">
        <button onclick="filterEmoji('all')" class="px-3 py-1.5 bg-gray-800 text-white rounded-lg text-sm font-medium" id="cat-all">全部</button>
        <button onclick="filterEmoji('smileys')" class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm" id="cat-smileys">😊 笑脸</button>
        <button onclick="filterEmoji('people')" class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm" id="cat-people">👋 人物</button>
        <button onclick="filterEmoji('nature')" class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm" id="cat-nature">🌿 自然</button>
        <button onclick="filterEmoji('food')" class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm" id="cat-food">🍕 食物</button>
        <button onclick="filterEmoji('travel')" class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm" id="cat-travel">🚗 旅行</button>
        <button onclick="filterEmoji('activities')" class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm" id="cat-activities">⚽ 活动</button>
        <button onclick="filterEmoji('objects')" class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm" id="cat-objects">💡 物品</button>
        <button onclick="filterEmoji('symbols')" class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm" id="cat-symbols">🔣 符号</button>
        <button onclick="filterEmoji('flags')" class="px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm" id="cat-flags">🏁 旗帜</button>
      </div>

      <div id="emoji-grid" class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 lg:grid-cols-10 gap-2"></div>

      <div id="emoji-detail" class="hidden mt-4 p-4 bg-blue-50 border border-blue-100 rounded-lg flex items-center gap-4">
        <span id="emoji-big" class="text-5xl"></span>
        <div>
          <div id="emoji-name" class="font-medium text-gray-800"></div>
          <div id="emoji-code" class="text-xs text-gray-500 font-mono mt-1"></div>
          <button onclick="copyEmoji()" class="mt-2 px-3 py-1 bg-white border border-gray-300 rounded text-xs hover:bg-gray-50">📋 复制 Emoji</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const EMOJIS = [
