  { e: '💰', n: ' money bag', c: 'objects', k: 'money cash wealth' },
  { e: '🔣', n: ' input symbols', c: 'symbols', k: 'symbols input' },
  { e: '♻️', n: ' recycling symbol', c: 'symbols', k: 'recycle green eco' },
  { e: '✅', n: ' check mark', c: 'symbols', k: 'check done yes complete' },
  { e: '❌', n: ' cross mark', c: 'symbols', k: 'cross cancel wrong no' },
  { e: '⚠️', n: ' warning', c: 'symbols', k: 'warning caution alert' },
  { e: '™️', n: ' trade mark', c: 'symbols', k: 'trademark tm' },
  { e: '🇨🇳', n: ' China', c: 'flags', k: 'china flag cn' },
  { e: '🇺🇸', n: ' United States', c: 'flags', k: 'us flag america' },
  { e: '🇬🇧', n: ' United Kingdom', c: 'flags', k: 'uk flag britain england' },
  { e: '🇯🇵', n: ' Japan', c: 'flags', k: 'japan flag jp' },
  { e: '🏁', n: ' chequered flag', c: 'flags', k: 'checkered flag finish race' },
];

let currentFilter = 'all';
let currentSearch = '';

function renderEmojis() {
  const grid = document.getElementById('emoji-grid');
  const filtered = EMOJIS.filter(e => {
    if (currentFilter !== 'all' && e.c !== currentFilter) return false;
    if (currentSearch && !e.k.toLowerCase().includes(currentSearch) && !e.n.toLowerCase().includes(currentSearch) && !e.e.includes(currentSearch)) return false;
    return true;
  });

  if (filtered.length === 0) {
    grid.innerHTML = '<div class="col-span-full text-center py-8 text-gray-400 text-sm">没有匹配的 Emoji</div>';
    return;
  }

  grid.innerHTML = filtered.map(e =>
    `<div class="p-3 bg-white border border-gray-200 rounded-lg text-center cursor-pointer hover:bg-blue-50 hover:border-blue-300 transition"
          onclick="selectEmoji('${e.e}', '${escapeHtml(e.n.trim())}')">
      <div class="text-2xl">${e.e}</div>
      <div class="text-xs text-gray-500 truncate mt-1">${e.n.trim()}</div>
    </div>`
  ).join('');
}

function searchEmoji() {
  currentSearch = document.getElementById('emoji-search').value.toLowerCase();
  renderEmojis();
}

function filterEmoji(cat) {
  currentFilter = cat;
  document.querySelectorAll('[id^="cat-"], [id="cat-all"]').forEach(el => {
    el.className = el.id === 'cat-' + cat || (cat === 'all' && el.id === 'cat-all')
      ? 'px-3 py-1.5 bg-gray-800 text-white rounded-lg text-sm font-medium'
      : 'px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm';
  });
  renderEmojis();
}

function selectEmoji(emoji, name) {
  document.getElementById('emoji-detail').classList.remove('hidden');
  document.getElementById('emoji-big').textContent = emoji;
  document.getElementById('emoji-name').textContent = name;
  document.getElementById('emoji-code').textContent = `U+${emoji.codePointAt(0).toString(16).toUpperCase().padStart(4, '0')}`;
}

function copyEmoji() {
  const emoji = document.getElementById('emoji-big').textContent;
  navigator.clipboard.writeText(emoji).then(() => {
    const btn = document.querySelector('[onclick="copyEmoji()"]');
    btn.textContent = '✅ 已复制';
    setTimeout(() => btn.textContent = '📋 复制 Emoji', 1500);
  });
}

function escapeHtml(s) { return String(s).replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[m]); }

renderEmojis();
</script>
