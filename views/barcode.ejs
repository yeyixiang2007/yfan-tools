<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="flex flex-wrap gap-2 mb-4">
        <button onclick="generateBarcode()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">✨ 生成条形码</button>
        <button onclick="downloadBarcode()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">💾 下载 PNG</button>
        <button onclick="clearAll()" class="px-4 py-2 bg-white border border-gray-300 text-gray-500 rounded-lg hover:bg-gray-50 text-sm font-medium">清空</button>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">编码内容</label>
        <input id="barcode-input" type="text" value="1234567890"
               class="w-full px-4 py-2 border border-gray-300 rounded-lg font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
               oninput="debounce(generateBarcode, 300)()">
      </div>

      <div class="mb-4 flex flex-wrap gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">格式</label>
          <select id="barcode-format" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" onchange="generateBarcode()">
            <option value="CODE128">CODE128</option>
            <option value="EAN13">EAN-13</option>
            <option value="UPC">UPC-A</option>
            <option value="CODE39">CODE39</option>
            <option value="ITF">ITF-14</option>
          </select>
          <p id="format-hint" class="text-xs text-gray-400 mt-1"></p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">宽度</label>
          <select id="barcode-width" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" onchange="generateBarcode()">
            <option value="1">细</option>
            <option value="2" selected>中</option>
            <option value="3">粗</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">高度</label>
          <select id="barcode-height" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" onchange="generateBarcode()">
            <option value="50">小</option>
            <option value="80" selected>中</option>
            <option value="120">大</option>
          </select>
        </div>
      </div>

      <div id="barcode-container" class="flex justify-center p-6 bg-white border border-gray-200 rounded-lg min-h-[100px]">
        <svg id="barcode-svg"></svg>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>

<script>
let debounceTimer = null;
function debounce(fn, ms) {
  return function() { clearTimeout(debounceTimer); debounceTimer = setTimeout(fn, ms); };
}

function generateBarcode() {
  const text = document.getElementById('barcode-input').value.trim();
  if (!text) return;

  const format = document.getElementById('barcode-format').value;
  const width = parseInt(document.getElementById('barcode-width').value);
  const height = parseInt(document.getElementById('barcode-height').value);

  try {
    const container = document.getElementById('barcode-container');
    const svg = document.getElementById('barcode-svg');
    // 恢复 SVG 容器
    container.innerHTML = '<svg id="barcode-svg"></svg>';
    
    // 格式提示
    const tips = {CODE128:'任意字符', EAN13:'12 或 13 位数字', UPC:'11 或 12 位数字', CODE39:'字母/数字/-./空格', ITF:'偶数位数字', codabar:'A-D 开头结尾的数字' };
    document.getElementById('format-hint').textContent = tips[format] || '';

    JsBarcode('#barcode-svg', text, {
      format: format,
      width: width,
      height: height,
      displayValue: true,
      fontSize: 16,
      margin: 10,
      background: '#ffffff',
      lineColor: '#000000'
    });
  } catch (e) {
    const msg = e.message && e.message !== 'undefined' ? e.message : '输入不符合 ' + format + ' 格式要求';
    document.getElementById('barcode-container').innerHTML = '<p class="text-red-500 text-sm">⚠️ ' + msg + '</p>';
  }
}

function downloadBarcode() {
  const svg = document.getElementById('barcode-svg');
  if (!svg || !svg.innerHTML) return;

  const svgData = new XMLSerializer().serializeToString(svg);
  const canvas = document.createElement('canvas');
  const ctx = canvas.getContext('2d');
  const img = new Image();

  img.onload = function() {
    canvas.width = img.width;
    canvas.height = img.height;
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.drawImage(img, 0, 0);

    const link = document.createElement('a');
    link.download = 'barcode.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
  };

  img.src = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(svgData)));
}

function clearAll() {
  document.getElementById('barcode-input').value = '';
  document.getElementById('barcode-svg').innerHTML = '';
}

generateBarcode();
</script>
