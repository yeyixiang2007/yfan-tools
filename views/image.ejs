<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="flex flex-wrap gap-2 mb-4">
        <button onclick="uploadImage()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">📁 选择图片</button>
        <button onclick="downloadResult()" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-sm font-medium" id="download-btn" style="display:none">💾 下载处理结果</button>
        <button onclick="resetAll()" class="px-4 py-2 bg-white border border-gray-300 text-gray-500 rounded-lg hover:bg-gray-50 text-sm font-medium">重置</button>
      </div>

      <input id="image-input" type="file" accept="image/*" class="hidden" onchange="handleImage(this)">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">原图</label>
          <div id="original-container" class="border border-gray-300 rounded-lg bg-gray-50 flex items-center justify-center min-h-[250px] text-sm text-gray-400">
            点击「选择图片」上传
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">处理后</label>
          <div id="processed-container" class="border border-gray-300 rounded-lg bg-gray-50 flex items-center justify-center min-h-[250px] text-sm text-gray-400">
            等待处理
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">质量 (%)</label>
          <input id="quality-slider" type="range" min="10" max="100" value="80" class="w-32" oninput="updateQuality()">
          <span id="quality-label" class="text-sm text-gray-600 ml-1">80%</span>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">最大宽度 (px)</label>
          <input id="max-width" type="number" value="800" min="100" max="4000" class="w-24 px-2 py-1 border border-gray-300 rounded text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">格式</label>
          <select id="format-select" class="px-3 py-1.5 border border-gray-300 rounded text-sm">
            <option value="jpeg">JPEG</option>
            <option value="png">PNG</option>
            <option value="webp">WebP</option>
          </select>
        </div>
        <div class="flex items-end">
          <button onclick="applyProcessing()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">⚙️ 应用</button>
        </div>
      </div>

      <div id="image-info" class="hidden p-4 bg-gray-50 rounded-lg">
        <h3 class="text-sm font-semibold text-gray-700 mb-2">📊 图片信息</h3>
        <div id="image-details" class="text-xs text-gray-500 space-y-1"></div>
      </div>
    </div>
  </div>
</div>

<script>
let originalImage = null;
let processedBlob = null;

function uploadImage() { document.getElementById('image-input').click(); }

function handleImage(input) {
  const file = input.files[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = function(e) {
    const img = new Image();
    img.onload = function() {
      originalImage = img;
      const container = document.getElementById('original-container');
      container.innerHTML = '';
      container.appendChild(img.cloneNode());
      img.style.maxWidth = '100%';
      img.style.maxHeight = '300px';
      img.style.objectFit = 'contain';

      showImageInfo(file, img);
      applyProcessing();
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function showImageInfo(file, img) {
  const info = document.getElementById('image-info');
  info.classList.remove('hidden');
  document.getElementById('image-details').innerHTML = `
    <div>文件名: ${file.name}</div>
    <div>大小: ${(file.size / 1024).toFixed(1)} KB</div>
    <div>尺寸: ${img.width} × ${img.height} px</div>
    <div>类型: ${file.type}</div>
  `;
}

function updateQuality() {
  const val = document.getElementById('quality-slider').value;
  document.getElementById('quality-label').textContent = val + '%';
}

function applyProcessing() {
  if (!originalImage) return;

  const quality = parseInt(document.getElementById('quality-slider').value) / 100;
  const maxWidth = parseInt(document.getElementById('max-width').value) || 800;
  const format = document.getElementById('format-select').value;

  const canvas = document.createElement('canvas');
  const ctx = canvas.getContext('2d');

  let w = originalImage.width;
  let h = originalImage.height;

  if (w > maxWidth) {
    h = h * maxWidth / w;
    w = maxWidth;
  }

  canvas.width = w;
  canvas.height = h;
  ctx.drawImage(originalImage, 0, 0, w, h);

  const mimeType = format === 'jpeg' ? 'image/jpeg' : format === 'png' ? 'image/png' : 'image/webp';
  canvas.toBlob(function(blob) {
    processedBlob = blob;
    const url = URL.createObjectURL(blob);
    const container = document.getElementById('processed-container');
    container.innerHTML = `<img src="${url}" style="max-width:100%;max-height:300px;object-fit:contain">`;

    document.getElementById('download-btn').style.display = 'inline-flex';

    // Show compression info
    const info = document.getElementById('image-details');
    if (info) {
      info.innerHTML += `<div class="text-green-600 font-medium">处理后: ${(blob.size / 1024).toFixed(1)} KB (${originalImage ? ((1 - blob.size / (originalImage.src ? (originalImage.src.length * 0.75) : fileSize)) * 100).toFixed(0) : ''}%)</div>`;
    }
  }, mimeType, quality);
}

function downloadResult() {
  if (!processedBlob) return;
  const format = document.getElementById('format-select').value;
  const a = document.createElement('a');
  a.href = URL.createObjectURL(processedBlob);
  a.download = 'processed.' + (format === 'jpeg' ? 'jpg' : format);
  a.click();
}

function resetAll() {
  document.getElementById('image-input').value = '';
  originalImage = null;
  processedBlob = null;
  document.getElementById('original-container').innerHTML = '点击「选择图片」上传';
  document.getElementById('processed-container').innerHTML = '等待处理';
  document.getElementById('image-info').classList.add('hidden');
  document.getElementById('download-btn').style.display = 'none';
}
</script>
