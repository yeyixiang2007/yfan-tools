<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">输入文本</label>
        <textarea id="hash-input" rows="6" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="输入要计算哈希的文本..."></textarea>
      </div>

      <!-- 选项 -->
      <div class="flex flex-wrap gap-4 mb-4">
        <div>
          <label class="block text-xs text-gray-500 mb-1">输入编码</label>
          <select id="hash-encoding" class="border border-gray-300 rounded-lg text-sm p-2" onchange="computeHashes()">
            <option value="text">文本</option>
            <option value="hex">Hex</option>
            <option value="base64">Base64</option>
          </select>
        </div>
      </div>

      <div class="mb-4 p-3 bg-yellow-50 border border-yellow-200 text-yellow-700 text-sm rounded-lg">
        ⚠️ 哈希是单向函数，不可逆。此工具纯前端计算，数据不会上传到服务器。
      </div>

      <!-- Results -->
      <div class="space-y-2" id="hash-results">
        <div class="flex items-center gap-2 p-3 bg-gray-50 border border-gray-200 rounded-lg hover:bg-white transition cursor-pointer group" onclick="copyHash(this)" data-algorithm="md5">
          <span class="text-xs font-bold text-gray-400 w-16 uppercase">MD5</span>
          <code id="hash-md5" class="flex-1 font-mono text-sm text-gray-800 break-all">—</code>
          <span class="text-xs text-blue-500 opacity-0 group-hover:opacity-100 transition">📋 复制</span>
        </div>
        <div class="flex items-center gap-2 p-3 bg-gray-50 border border-gray-200 rounded-lg hover:bg-white transition cursor-pointer group" onclick="copyHash(this)" data-algorithm="sha1">
          <span class="text-xs font-bold text-gray-400 w-16 uppercase">SHA-1</span>
          <code id="hash-sha1" class="flex-1 font-mono text-sm text-gray-800 break-all">—</code>
          <span class="text-xs text-blue-500 opacity-0 group-hover:opacity-100 transition">📋 复制</span>
        </div>
        <div class="flex items-center gap-2 p-3 bg-gray-50 border border-gray-200 rounded-lg hover:bg-white transition cursor-pointer group" onclick="copyHash(this)" data-algorithm="sha256">
          <span class="text-xs font-bold text-gray-400 w-16 uppercase">SHA-256</span>
          <code id="hash-sha256" class="flex-1 font-mono text-sm text-gray-800 break-all">—</code>
          <span class="text-xs text-blue-500 opacity-0 group-hover:opacity-100 transition">📋 复制</span>
        </div>
        <div class="flex items-center gap-2 p-3 bg-gray-50 border border-gray-200 rounded-lg hover:bg-white transition cursor-pointer group" onclick="copyHash(this)" data-algorithm="sha512">
          <span class="text-xs font-bold text-gray-400 w-16 uppercase">SHA-512</span>
          <code id="hash-sha512" class="flex-1 font-mono text-sm text-gray-800 break-all">—</code>
          <span class="text-xs text-blue-500 opacity-0 group-hover:opacity-100 transition">📋 复制</span>
        </div>
      </div>

      <!-- 文件哈希 -->
      <div class="mt-6 border-t border-gray-100 pt-6">
        <h3 class="text-sm font-medium text-gray-700 mb-3">📁 文件哈希</h3>
        <div id="file-hash-zone" class="mb-3 border-2 border-dashed border-gray-300 rounded-lg p-6 text-center text-gray-400 text-sm cursor-pointer hover:border-blue-400 hover:text-blue-500 transition" onclick="document.getElementById('file-hash-input').click()" ondragover="this.classList.add('border-blue-500','bg-blue-50')" ondragleave="this.classList.remove('border-blue-500','bg-blue-50')" ondrop="handleFileHashDrop(event)">
          📂 拖拽文件到此处，或点击选择文件（浏览器本地计算，不上传）
        </div>
        <input id="file-hash-input" type="file" class="hidden" onchange="hashFile(this)">
        <div id="file-hash-progress" class="hidden mb-3">
          <div class="w-full bg-gray-200 rounded-full h-2">
            <div id="file-hash-bar" class="bg-blue-600 h-2 rounded-full transition-all" style="width: 0%"></div>
          </div>
          <p id="file-hash-status" class="text-xs text-gray-400 mt-1">计算中...</p>
        </div>
        <div id="file-hash-result" class="hidden space-y-1">
          <div class="flex items-center gap-2 p-2 bg-green-50 border border-green-200 rounded-lg">
            <span id="file-hash-name" class="text-xs text-gray-500 truncate max-w-[200px]"></span>
            <code id="file-hash-value" class="flex-1 font-mono text-xs break-all text-gray-800"></code>
            <span class="text-xs text-blue-500 cursor-pointer hover:text-blue-700" onclick="copyFileHash()">📋 复制</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function strToBytes(str) {
  const encoder = new TextEncoder();
  return encoder.encode(str);
}

function hexToBytes(hex) {
  hex = hex.replace(/\s/g, '');
  if (hex.length % 2 !== 0) throw new Error('Hex 字符串长度必须为偶数');
  const bytes = new Uint8Array(hex.length / 2);
  for (let i = 0; i < bytes.length; i++) {
    bytes[i] = parseInt(hex.substring(i * 2, i * 2 + 2), 16);
  }
  return bytes;
}

function base64ToBytes(b64) {
  const binary = atob(b64.replace(/\s/g, ''));
  const bytes = new Uint8Array(binary.length);
  for (let i = 0; i < binary.length; i++) {
    bytes[i] = binary.charCodeAt(i);
  }
  return bytes;
}

async function computeHashes() {
  const input = document.getElementById('hash-input').value;
  const encoding = document.getElementById('hash-encoding').value;
  const algorithms = ['MD5', 'SHA-1', 'SHA-256', 'SHA-512'];
  const outputIds = ['hash-md5', 'hash-sha1', 'hash-sha256', 'hash-sha512'];

  if (!input) {
    outputIds.forEach(id => document.getElementById(id).textContent = '—');
    return;
  }

  try {
    let data;
    if (encoding === 'hex') {
      data = hexToBytes(input);
    } else if (encoding === 'base64') {
      data = base64ToBytes(input);
    } else {
      data = strToBytes(input);
    }

    for (let i = 0; i < algorithms.length; i++) {
      const hashBuffer = await crypto.subtle.digest(algorithms[i], data);
      const hashArray = Array.from(new Uint8Array(hashBuffer));
      const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
      document.getElementById(outputIds[i]).textContent = hashHex;
    }
  } catch (e) {
    outputIds.forEach(id => document.getElementById(id).textContent = '❌ ' + e.message);
  }
}

function copyHash(el) {
  const code = el.querySelector('code');
  if (!code || !code.textContent || code.textContent === '—') return;
  navigator.clipboard.writeText(code.textContent).then(() => {
    const label = el.querySelector('span:first-child');
    const orig = label.textContent;
    label.textContent = '✅';
    setTimeout(() => label.textContent = orig, 1500);
  })
      .catch(function(err) { console.error(err); });;
}

function copyFileHash() {
  const el = document.getElementById('file-hash-value');
  if (!el || !el.textContent) return;
  navigator.clipboard.writeText(el.textContent);
}

// 文件哈希
function handleFileHashDrop(e) {
  e.preventDefault();
  document.getElementById('file-hash-zone').classList.remove('border-blue-500', 'bg-blue-50');
  const files = e.dataTransfer.files;
  if (files.length > 0) processFileHash(files[0]);
}

function hashFile(el) {
  if (el.files.length > 0) processFileHash(el.files[0]);
  el.value = '';
}

async function processFileHash(file) {
  const resultDiv = document.getElementById('file-hash-result');
  const progressDiv = document.getElementById('file-hash-progress');
  const bar = document.getElementById('file-hash-bar');
  const status = document.getElementById('file-hash-status');

  resultDiv.classList.add('hidden');
  progressDiv.classList.remove('hidden');
  bar.style.width = '0%';
  status.textContent = '正在计算 ' + file.name + ' (' + formatSize(file.size) + ')...';

  try {
    const buffer = await file.arrayBuffer();
    const hashBuffer = await crypto.subtle.digest('SHA-256', buffer);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');

    bar.style.width = '100%';
    status.textContent = '✓ 计算完成';

    document.getElementById('file-hash-name').textContent = file.name;
    document.getElementById('file-hash-value').textContent = hashHex;
    resultDiv.classList.remove('hidden');
  } catch (e) {
    status.textContent = '❌ 计算失败: ' + e.message;
  }

  setTimeout(() => progressDiv.classList.add('hidden'), 2000);
}

function formatSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
}

document.getElementById('hash-input').addEventListener('input', computeHashes);
document.getElementById('hash-encoding').addEventListener('change', computeHashes);
</script>
