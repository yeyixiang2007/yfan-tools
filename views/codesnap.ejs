<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">代码</label>
          <textarea id="code-input" rows="8" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" placeholder="粘贴代码..." oninput="renderCard()">function hello() {
  console.log("Hello, World!");
}</textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">预览</label>
          <canvas id="preview-canvas" width="680" height="300" class="w-full rounded-xl border border-gray-200" style="max-width:680px;max-height:500px"></canvas>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 mb-4">
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">主题</label>
          <select id="theme-select" class="px-3 py-2 border border-gray-300 rounded-lg text-sm" onchange="renderCard()">
            <option value="monokai" selected>Monokai</option>
            <option value="nord">Nord</option>
            <option value="darcula">Darcula</option>
            <option value="github">GitHub Light</option>
            <option value="one-dark">One Dark</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">背景</label>
          <select id="bg-select" class="px-3 py-2 border border-gray-300 rounded-lg text-sm" onchange="renderCard()">
            <option value="none">无</option>
            <option value="sunset" selected>日落渐变</option>
            <option value="ocean">海洋渐变</option>
            <option value="forest">森林渐变</option>
            <option value="midnight">暗夜渐变</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">语言</label>
          <select id="lang-select" class="px-3 py-2 border border-gray-300 rounded-lg text-sm" onchange="renderCard()">
            <option value="js">JavaScript</option>
            <option value="py">Python</option>
            <option value="go">Go</option>
            <option value="rs">Rust</option>
            <option value="java">Java</option>
            <option value="ts">TypeScript</option>
            <option value="html">HTML</option>
            <option value="css">CSS</option>
            <option value="sh">Shell</option>
          </select>
        </div>
      </div>

      <div class="flex flex-wrap gap-2">
        <button onclick="downloadPNG()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">⬇️ 下载 PNG</button>
        <button onclick="copyHTML()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">📋 复制 HTML</button>
      </div>
    </div>
  </div>
</div>

<script>
// ── Themes ──
const THEMES = {
  monokai:  { bg:'#272822', fg:'#f8f8f2', kw:'#f92672', str:'#e6db74', cmt:'#75715e' },
  nord:     { bg:'#2e3440', fg:'#d8dee9', kw:'#81a1c1', str:'#a3be8c', cmt:'#4c566a' },
  darcula:  { bg:'#2b2b2b', fg:'#a9b7c6', kw:'#cc7832', str:'#6a8759', cmt:'#808080' },
  github:   { bg:'#ffffff', fg:'#24292e', kw:'#d73a49', str:'#032f62', cmt:'#6a737d' },
  'one-dark':{bg:'#282c34',fg:'#abb2bf',kw:'#c678dd',str:'#98c379',cmt:'#5c6370'},
};

const GRADIENTS = {
  none:     { type:'solid', color:'#1e1e1e' },
  sunset:   { type:'grad', colors:['#fc5c7d','#6a82fb'] },
  ocean:    { type:'grad', colors:['#0f2027','#203a43','#2c5364'] },
  forest:   { type:'grad', colors:['#134e5e','#71b280'] },
  midnight: { type:'grad', colors:['#1a1a2e','#16213e','#0f3460'] },
};

// ── Keywords by language ──
const KEYWORDS = {
  js:   new Set(['function','return','const','let','var','if','else','for','while','class','import','export','from','default','async','await','try','catch','throw','new','this','true','false','null','undefined','typeof','in','of','switch','case','break','continue']),
  py:   new Set(['def','return','if','else','elif','for','while','import','from','class','self','True','False','None','try','except','raise','with','as','in','not','and','or','lambda','yield','pass','break','continue']),
  go:   new Set(['func','return','if','else','for','range','var','type','struct','interface','import','package','defer','go','chan','map','nil','true','false','make','append','len']),
  rs:   new Set(['fn','let','mut','return','if','else','for','while','match','struct','enum','impl','trait','pub','use','mod','self','true','false','Some','None','Ok','Err','as','in','ref']),
  java: new Set(['public','private','protected','static','final','class','interface','enum','extends','implements','return','if','else','for','while','new','this','null','true','false','void','int','String','boolean','try','catch','throw','import','package']),
  ts:   new Set(['function','return','const','let','var','if','else','for','while','class','import','export','from','default','async','await','interface','type','extends','implements','new','this','true','false','null','undefined','enum']),
  html: new Set([]),
  css:  new Set([]),
  sh:   new Set(['if','then','else','fi','for','do','done','while','function','return','export','local','echo','exit','source']),
};

// ── Tokenise code into coloured spans ──
function tokenise(code, lang) {
  var kw = KEYWORDS[lang] || new Set();
  var tokens = [];
  var i = 0;
  while (i < code.length) {
    // String literals
    if (code[i] === '"' || code[i] === "'" || code[i] === '`') {
      var q = code[i], s = q; i++;
      while (i < code.length && code[i] !== q) { if (code[i] === '\\') { s += code[i] + (code[i+1]||''); i+=2; } else { s += code[i]; i++; } }
      s += code[i]||''; i++;
      tokens.push({ t:'str', v:s }); continue;
    }
    // Single-line comment
    if (code[i] === '/' && code[i+1] === '/') {
      var c = '//'; i+=2;
      while (i < code.length && code[i] !== '\n') { c += code[i]; i++; }
      tokens.push({ t:'cmt', v:c }); continue;
    }
    // Block comment
    if (code[i] === '/' && code[i+1] === '*') {
      var c = '/*'; i+=2;
      while (i < code.length && !(code[i] === '*' && code[i+1] === '/')) { c += code[i]; i++; }
      c += '*/'; i+=2;
      tokens.push({ t:'cmt', v:c }); continue;
    }
    // Python/shell comment
    if (code[i] === '#' && (lang === 'py' || lang === 'sh')) {
      var c = '#'; i++;
      while (i < code.length && code[i] !== '\n') { c += code[i]; i++; }
      tokens.push({ t:'cmt', v:c }); continue;
    }
    // Number literals
    if (/[0-9]/.test(code[i]) && (i===0 || /[\s\(\{\[\,\=\+\-\*\/\%\&\|\<\>\:;]/.test(code[i-1]))) {
      var n = '';
      while (i < code.length && /[0-9\.xXa-fA-f]/.test(code[i])) { n += code[i]; i++; }
      tokens.push({ t:'num', v:n }); continue;
    }
    // Identifiers / keywords
    if (/[a-zA-Z_$]/.test(code[i])) {
      var w = '';
      while (i < code.length && /[a-zA-Z0-9_$]/.test(code[i])) { w += code[i]; i++; }
      if (kw.has(w)) tokens.push({ t:'kw', v:w });
      else tokens.push({ t:'txt', v:w });
      continue;
    }
    // Whitespace
    if (code[i] === ' ' || code[i] === '\t' || code[i] === '\n') {
      tokens.push({ t:'ws', v:code[i] }); i++; continue;
    }
    tokens.push({ t:'txt', v:code[i] }); i++;
  }
  return tokens;
}

// ── Measure text width ──
var _canvas = document.createElement('canvas');
var _ctx = _canvas.getContext('2d');
function measureText(font, text) {
  _ctx.font = font;
  return _ctx.measureText(text).width;
}

// ── Render card on canvas ──
var CARD_W = 680;
var PAD_X = 24, PAD_Y = 18;
var LINE_H = 20; // line height
var FONT = '13px "SF Mono", "Fira Code", "Consolas", monospace';
var FONT_BOLD = 'bold 13px "SF Mono", "Fira Code", "Consolas", monospace';
var TAB_W = 8;

function wrapLines(font, text) {
  var lines = [];
  var cur = '';
  var maxW = CARD_W - PAD_X * 2 - 16; // inner content width
  _ctx.font = font;
  for (var i = 0; i < text.length; i++) {
    var ch = text[i];
    if (ch === '\t') ch = ' '.repeat(TAB_W);
    var test = cur + ch;
    if (_ctx.measureText(test).width > maxW && cur.length > 0) {
      lines.push(cur);
      cur = ch;
    } else {
      cur = test;
    }
  }
  if (cur) lines.push(cur);
  return lines;
}

function renderCard() {
  var code = document.getElementById('code-input').value;
  var themeName = document.getElementById('theme-select').value;
  var bgName = document.getElementById('bg-select').value;
  var lang = document.getElementById('lang-select').value;
  var theme = THEMES[themeName];
  var bg = GRADIENTS[bgName];

  // Tokenise code
  var tokens = tokenise(code, lang);

  // Build coloured lines (each line is array of {text, color, bold?})
  var colouredLines = [];
  var curLine = [];
  for (var t = 0; t < tokens.length; t++) {
    var tok = tokens[t];
    var color, bold;
    switch (tok.t) {
      case 'kw': color = theme.kw; bold = true; break;
      case 'str': color = theme.str; break;
      case 'cmt': color = theme.cmt; break;
      case 'num': color = '#a6e22e'; break;
      case 'txt': color = theme.fg; break;
      case 'ws': color = null; break;
      default: color = theme.fg;
    }
    var chars = tok.v.split('');
    for (var c = 0; c < chars.length; c++) {
      if (chars[c] === '\n') {
        colouredLines.push(curLine);
        curLine = [];
      } else {
        curLine.push({ ch: chars[c], color: color, bold: bold || false });
      }
    }
  }
  if (curLine.length > 0) colouredLines.push(curLine);

  // Wrap long lines
  var displayLines = [];
  for (var li = 0; li < colouredLines.length; li++) {
    var line = colouredLines[li];
    // Build flat text for wrapping check
    var flat = line.map(function(s) { return s.ch; }).join('');
    var wrapped = wrapLines(FONT, flat);
    if (wrapped.length <= 1) {
      displayLines.push(line);
    } else {
      var ptr = 0;
      for (var w = 0; w < wrapped.length; w++) {
        var sub = [];
        var wlen = 0;
        while (ptr < line.length && wlen < wrapped[w].length) {
          sub.push(line[ptr]);
          wlen += line[ptr].ch.length;
          ptr++;
        }
        displayLines.push(sub);
      }
    }
  }

  // Calculate canvas height
  var headerH = 16 + 10; // top bar height
  var footerH = 8;
  var contentH = displayLines.length * LINE_H;
  var canvasH = PAD_Y + headerH + contentH + footerH + PAD_Y;
  if (canvasH < 120) canvasH = 120;
  if (canvasH > 2000) canvasH = 2000;

  var canvas = document.getElementById('preview-canvas');
  canvas.width = CARD_W;
  canvas.height = canvasH;
  var ctx = canvas.getContext('2d');

  // ── Background ──
  if (bg.type === 'grad') {
    var grad = ctx.createLinearGradient(0, 0, CARD_W, canvasH);
    for (var g = 0; g < bg.colors.length; g++) {
      grad.addColorStop(g / (bg.colors.length - 1 || 1), bg.colors[g]);
    }
    ctx.fillStyle = grad;
  } else {
    ctx.fillStyle = bg.color;
  }
  ctx.fillRect(0, 0, CARD_W, canvasH);

  // ── Card ──
  var cardX = PAD_X, cardY = PAD_Y;
  var cardW = CARD_W - PAD_X * 2;
  var cardH = canvasH - PAD_Y * 2;
  var radius = 16;

  // Shadow
  ctx.shadowColor = 'rgba(0,0,0,0.3)';
  ctx.shadowBlur = 30;
  ctx.shadowOffsetY = 8;
  ctx.beginPath();
  ctx.roundRect(cardX, cardY, cardW, cardH, radius);
  ctx.fillStyle = theme.bg;
  ctx.fill();
  ctx.shadowColor = 'transparent';
  ctx.shadowBlur = 0;
  ctx.shadowOffsetY = 0;

  // Card background
  ctx.beginPath();
  ctx.roundRect(cardX, cardY, cardW, cardH, radius);
  ctx.fillStyle = theme.bg;
  ctx.fill();

  // ── Traffic lights ──
  var dotY = cardY + 14;
  var dotX = cardX + 16;
  ctx.beginPath(); ctx.arc(dotX, dotY, 6, 0, Math.PI * 2); ctx.fillStyle = '#ff5f57'; ctx.fill();
  ctx.beginPath(); ctx.arc(dotX + 18, dotY, 6, 0, Math.PI * 2); ctx.fillStyle = '#febc2e'; ctx.fill();
  ctx.beginPath(); ctx.arc(dotX + 36, dotY, 6, 0, Math.PI * 2); ctx.fillStyle = '#28c840'; ctx.fill();

  // Language label
  ctx.font = '11px monospace';
  ctx.fillStyle = 'rgba(255,255,255,0.25)';
  ctx.textAlign = 'right';
  ctx.fillText(lang.toUpperCase(), cardX + cardW - 14, dotY + 4);

  // ── Code lines ──
  ctx.textAlign = 'left';
  var codeY = cardY + 40 + 14; // baseline of first line
  for (var li = 0; li < displayLines.length; li++) {
    var line = displayLines[li];
    var x = cardX + 16;
    for (var si = 0; si < line.length; si++) {
      var span = line[si];
      if (span.ch === '\t') {
        ctx.fillText('        ', x, codeY);
        x += _ctx.measureText('        ').width;
        continue;
      }
      ctx.font = span.bold ? FONT_BOLD : FONT;
      ctx.fillStyle = span.color || theme.fg;
      ctx.fillText(span.ch, x, codeY);
      x += _ctx.measureText(span.ch).width;
    }
    codeY += LINE_H;
  }

  // ── Update download canvas reference ──
  window._codeCanvas = canvas;
}

// roundRect polyfill for canvas
if (!CanvasRenderingContext2D.prototype.roundRect) {
  CanvasRenderingContext2D.prototype.roundRect = function(x, y, w, h, r) {
    if (r > w/2) r = w/2;
    if (r > h/2) r = h/2;
    this.moveTo(x + r, y);
    this.lineTo(x + w - r, y);
    this.quadraticCurveTo(x + w, y, x + w, y + r);
    this.lineTo(x + w, y + h - r);
    this.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
    this.lineTo(x + r, y + h);
    this.quadraticCurveTo(x, y + h, x, y + h - r);
    this.lineTo(x, y + r);
    this.quadraticCurveTo(x, y, x + r, y);
    return this;
  };
}

// ── Download ──
function downloadPNG() {
  var canvas = window._codeCanvas;
  if (!canvas || canvas.width === 0) return;
  var link = document.createElement('a');
  link.download = 'code-snippet.png';
  link.href = canvas.toDataURL('image/png');
  link.click();
}

// ── Copy HTML ──
function copyHTML() {
  var canvas = window._codeCanvas;
  if (!canvas) return;
  var dataUrl = canvas.toDataURL('image/png');
  var html = '<div style="max-width:680px">\n  <img src="' + dataUrl + '" style="max-width:100%;height:auto" alt="Code Snippet"/>\n</div>';
  navigator.clipboard.writeText(html).then(function() {
    var btn = document.querySelector('[onclick^="copyHTML"]');
    btn.textContent = '✅ 已复制';
    setTimeout(function() { btn.textContent = '📋 复制 HTML'; }, 1500);
  });
}

renderCard();
</script>