<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="flex flex-wrap gap-2 mb-4">
        <div class="flex items-center gap-2">
          <input type="color" id="color-picker" value="#3b82f6" oninput="updateFromPicker()" class="w-10 h-10 p-0.5 border border-gray-300 rounded cursor-pointer">
          <span class="text-sm text-gray-500">或输入</span>
          <input id="color-hex" type="text" value="#3b82f6" placeholder="#RRGGBB" maxlength="7" class="w-24 px-3 py-2 border border-gray-300 rounded-lg font-mono text-sm uppercase focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" oninput="updateFromHex()">
        </div>
        <button onclick="copyColor('hex')" class="px-3 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm">📋 HEX</button>
        <button onclick="copyColor('rgb')" class="px-3 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm">📋 RGB</button>
        <button onclick="copyColor('hsl')" class="px-3 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm">📋 HSL</button>
        <button onclick="copyColor('cmyk')" class="px-3 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm">📋 CMYK</button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
          <div id="color-preview" class="w-full h-48 rounded-xl border-2 border-gray-200 flex items-center justify-center text-2xl font-bold shadow-inner" style="background:#3b82f6">🐙</div>
        </div>
        <div class="space-y-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">HEX</label>
            <input id="val-hex" readonly class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg font-mono text-sm text-gray-800">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">RGB</label>
            <input id="val-rgb" readonly class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg font-mono text-sm text-gray-800">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">HSL</label>
            <input id="val-hsl" readonly class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg font-mono text-sm text-gray-800">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">CMYK</label>
            <input id="val-cmyk" readonly class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg font-mono text-sm text-gray-800">
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">明度</label>
              <div id="val-lightness" class="text-sm font-medium text-gray-800"></div>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">色温</label>
              <div id="val-temp" class="text-sm font-medium text-gray-800"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-1 mb-4">
        <div class="w-full text-sm font-medium text-gray-700 mb-1">🎨 预设颜色</div>
        <div class="flex flex-wrap gap-2">
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#ef4444" onclick="setColor('#ef4444')" title="红色"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#f97316" onclick="setColor('#f97316')" title="橙色"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#eab308" onclick="setColor('#eab308')" title="黄色"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#22c55e" onclick="setColor('#22c55e')" title="绿色"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#3b82f6" onclick="setColor('#3b82f6')" title="蓝色"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#8b5cf6" onclick="setColor('#8b5cf6')" title="紫色"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#ec4899" onclick="setColor('#ec4899')" title="粉色"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#000000" onclick="setColor('#000000')" title="黑色"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#ffffff" onclick="setColor('#ffffff')" title="白色"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#78716c" onclick="setColor('#78716c')" title="灰色"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#0ea5e9" onclick="setColor('#0ea5e9')" title="天蓝"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#10b981" onclick="setColor('#10b981')" title="翡翠"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#f43f5e" onclick="setColor('#f43f5e')" title="玫瑰红"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#6366f1" onclick="setColor('#6366f1')" title="靛蓝"></div>
          <div class="w-8 h-8 rounded-lg cursor-pointer border border-gray-200 hover:scale-110 transition" style="background:#14b8a6" onclick="setColor('#14b8a6')" title="青绿"></div>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">R</label>
          <input id="slider-r" type="range" min="0" max="255" value="59" oninput="updateFromSliders()" class="w-full accent-red-500">
          <span id="val-r" class="text-xs font-mono text-gray-500">59</span>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">G</label>
          <input id="slider-g" type="range" min="0" max="255" value="130" oninput="updateFromSliders()" class="w-full accent-green-500">
          <span id="val-g" class="text-xs font-mono text-gray-500">130</span>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">B</label>
          <input id="slider-b" type="range" min="0" max="255" value="246" oninput="updateFromSliders()" class="w-full accent-blue-500">
          <span id="val-b" class="text-xs font-mono text-gray-500">246</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3), 16);
  const g = parseInt(hex.slice(3,5), 16);
  const b = parseInt(hex.slice(5,7), 16);
  return { r, g, b };
}

function rgbToHsl(r, g, b) {
  r /= 255; g /= 255; b /= 255;
  const max = Math.max(r, g, b), min = Math.min(r, g, b);
  let h, s, l = (max + min) / 2;
  if (max === min) { h = s = 0; }
  else {
    const d = max - min;
    s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
    switch (max) {
      case r: h = ((g - b) / d + (g < b ? 6 : 0)) / 6; break;
      case g: h = ((b - r) / d + 2) / 6; break;
      case b: h = ((r - g) / d + 4) / 6; break;
    }
  }
  return { h: Math.round(h * 360), s: Math.round(s * 100), l: Math.round(l * 100) };
}

function rgbToCmyk(r, g, b) {
  const cR = r / 255, cG = g / 255, cB = b / 255;
  const k = 1 - Math.max(cR, cG, cB);
  if (k === 1) return { c: 0, m: 0, y: 0, k: 100 };
  const c = Math.round((1 - cR - k) / (1 - k) * 100);
  const m = Math.round((1 - cG - k) / (1 - k) * 100);
  const y = Math.round((1 - cB - k) / (1 - k) * 100);
  return { c, m, y, k: Math.round(k * 100) };
}

function updateColor(hex) {
  hex = hex.toUpperCase();
  const { r, g, b } = hexToRgb(hex);
  const hsl = rgbToHsl(r, g, b);
  const cmyk = rgbToCmyk(r, g, b);

  document.getElementById('color-preview').style.backgroundColor = hex;
  document.getElementById('color-hex').value = hex;
  document.getElementById('color-picker').value = hex;
  document.getElementById('val-hex').value = hex;

  const rgbStr = `rgb(${r}, ${g}, ${b})`;
  const hslStr = `hsl(${hsl.h}, ${hsl.s}%, ${hsl.l}%)`;
  const cmykStr = `cmyk(${cmyk.c}%, ${cmyk.m}%, ${cmyk.y}%, ${cmyk.k}%)`;

  document.getElementById('val-rgb').value = rgbStr;
  document.getElementById('val-hsl').value = hslStr;
  document.getElementById('val-cmyk').value = cmykStr;

  document.getElementById('slider-r').value = r;
  document.getElementById('slider-g').value = g;
  document.getElementById('slider-b').value = b;
  document.getElementById('val-r').textContent = r;
  document.getElementById('val-g').textContent = g;
  document.getElementById('val-b').textContent = b;

  // Lightness description
  const lightness = hsl.l < 25 ? '深色' : hsl.l < 50 ? '中深' : hsl.l < 75 ? '中浅' : '浅色';
  document.getElementById('val-lightness').textContent = lightness + ` (${hsl.l}%)`;

  // Temperature
  const temp = hsl.h >= 0 && hsl.h < 60 ? '暖色' : hsl.h < 180 ? '冷色' : hsl.h < 270 ? '中性偏冷' : '暖色';
  document.getElementById('val-temp').textContent = temp;
}

function updateFromPicker() {
  updateColor(document.getElementById('color-picker').value);
}

function updateFromHex() {
  let hex = document.getElementById('color-hex').value.trim();
  if (hex.length === 6 && !hex.startsWith('#')) hex = '#' + hex;
  if (/^#[0-9a-fA-F]{6}$/.test(hex)) updateColor(hex);
}

function updateFromSliders() {
  const r = parseInt(document.getElementById('slider-r').value);
  const g = parseInt(document.getElementById('slider-g').value);
  const b = parseInt(document.getElementById('slider-b').value);
  const hex = '#' + [r,g,b].map(v => v.toString(16).padStart(2,'0')).join('');
  updateColor(hex);
}

function setColor(hex) { updateColor(hex); }

function copyColor(type) {
  const map = { hex: 'val-hex', rgb: 'val-rgb', hsl: 'val-hsl', cmyk: 'val-cmyk' };
  const el = document.getElementById(map[type]);
  if (!el) return;
  navigator.clipboard.writeText(el.value).then(() => {
    const btns = document.querySelectorAll('[onclick^="copyColor"]');
    for (const btn of btns) {
      if (btn.textContent.includes(type.toUpperCase()) || btn.textContent.includes('CMYK') || btn.textContent.includes('HSL')) {
        btn.textContent = '✅';
        setTimeout(() => {
          btn.textContent = { hex: '📋 HEX', rgb: '📋 RGB', hsl: '📋 HSL', cmyk: '📋 CMYK' }[type];
        }, 1000);
        break;
      }
    }
  })
      .catch(function(err) { console.error(err); });;
}

updateColor('#3B82F6');
</script>
