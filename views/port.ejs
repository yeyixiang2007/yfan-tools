var WELL_KNOWN_PORTS = [22, 80, 443, 3306, 5432, 6379, 8080, 8443, 9092, 9200, 27017, 3000, 5000, 9000, 6379, 11211, 3389, 5900, 1433, 1521, 2181, 2375, 5672, 6443];

function lookupPort() {
  let port = parseInt(document.getElementById('port-input').value);
  if (isNaN(port) || port < 1) port = 1;
  if (port > 65535) port = 65535;

  document.getElementById('port-number').textContent = port;
  const details = document.getElementById('port-details');
  const data = PORT_DATA[port];

  if (data) {
    const category = port < 1024 ? 'Well-Known (0-1023)' : port < 49152 ? 'Registered (1024-49151)' : 'Dynamic (49152-65535)';
    details.innerHTML = [
      '<div class="p-4 bg-gray-50 border border-gray-100 rounded-lg">',
        '<div class="text-xs text-gray-500 mb-1">服务名称</div>',
        '<div class="text-lg font-bold text-gray-800">', data.name, '</div>',
      '</div>',
      '<div class="p-4 bg-gray-50 border border-gray-100 rounded-lg">',
        '<div class="text-xs text-gray-500 mb-1">协议</div>',
        '<div class="text-lg font-bold text-gray-800">', data.proto, '</div>',
      '</div>',
      '<div class="p-4 bg-gray-50 border border-gray-100 rounded-lg md:col-span-2">',
        '<div class="text-xs text-gray-500 mb-1">描述</div>',
        '<div class="text-sm text-gray-700">', data.desc, '</div>',
        '<div class="text-xs text-gray-400 mt-1">', category, '</div>',
      '</div>'
    ].join('');
  } else {
    const category = port < 1024 ? 'Well-Known (0-1023)' : port < 49152 ? 'Registered (1024-49151)' : 'Dynamic (49152-65535)';
    details.innerHTML = [
      '<div class="p-4 bg-gray-50 border border-gray-100 rounded-lg md:col-span-2">',
        '<div class="text-xs text-gray-500 mb-1">状态</div>',
        '<div class="text-sm text-gray-700">未注册或已知服务</div>',
        '<div class="text-xs text-gray-400 mt-1">', category, '</div>',
      '</div>'
    ].join('');
  }

  // Render well-known port grid
  const wkContainer = document.getElementById('port-well-known');
  wkContainer.innerHTML = WELL_KNOWN_PORTS.map(function(p) {
    const d = PORT_DATA[p];
    if (!d) return '';
    const active = p === port;
    return [
      '<div class="p-2 bg-white border ', (active ? 'border-blue-400 bg-blue-50' : 'border-gray-200'), ' rounded-lg cursor-pointer hover:bg-gray-50"',
             ' onclick="document.getElementById('port-input').value=', p, ';lookupPort()">',
        '<div class="font-bold text-gray-800">', p, '</div>',
        '<div class="text-gray-500 truncate">', d.name, '</div>',
      '</div>'
    ].join('');
  }).join('');
}

lookupPort();
</script>
