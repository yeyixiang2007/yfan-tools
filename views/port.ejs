<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="mb-6">
        <input id="port-input" type="number" min="1" max="65535" value="80"
               class="w-full max-w-xs px-4 py-2 border border-gray-300 rounded-lg font-mono text-lg text-center focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
               oninput="lookupPort()">
      </div>

      <div id="port-result" class="space-y-2">
        <div id="port-info" class="p-4 bg-blue-50 border border-blue-100 rounded-lg">
          <div class="text-xs text-gray-500 mb-1">端口号</div>
          <div class="text-2xl font-mono font-bold text-gray-800" id="port-number">80</div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3" id="port-details"></div>
      </div>

      <div class="mt-6">
        <h3 class="text-sm font-medium text-gray-700 mb-2">📋 常用端口速查</h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-xs" id="port-well-known"></div>
      </div>
    </div>
  </div>
</div>

