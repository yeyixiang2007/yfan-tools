<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; иҝ”еӣһйҰ–йЎө</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <div class="flex flex-wrap gap-2 mb-4">
        <button onclick="generateChart()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium">рҹ“Ҡ з”ҹжҲҗ</button>
        <button onclick="copyResult()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">рҹ“Ӣ еӨҚеҲ¶</button>
        <button onclick="clearAll()" class="px-4 py-2 bg-white border border-gray-300 text-gray-500 rounded-lg hover:bg-gray-50 text-sm font-medium">жё…з©ә</button>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-4">
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">еӣҫиЎЁзұ»еһӢ</label>
          <select id="chart-type" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
            <option value="bar">жҹұзҠ¶еӣҫ</option>
            <option value="hbar">жЁӘеҗ‘жҹұзҠ¶еӣҫ</option>
            <option value="line">жҠҳзәҝеӣҫ</option>
            <option value="pie">йҘјеӣҫ</option>
            <option value="stack">е ҶеҸ еӣҫ</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">е®ҪеәҰ</label>
          <input id="chart-width" type="number" min="20" max="120" value="50" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">жҺ’еәҸ</label>
          <select id="chart-sort" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
            <option value="none">дёҚжҺ’еәҸ</option>
            <option value="desc">д»ҺеӨ§еҲ°е°Ҹ</option>
            <option value="asc">д»Һе°ҸеҲ°еӨ§</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">жҳҫзӨәеҖј</label>
          <select id="chart-showval" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
            <option value="yes">жҳҫзӨә</option>
            <option value="no">йҡҗи—Ҹ</option>
          </select>
        </div>
        <div class="flex items-end">
          <label class="flex items-center gap-1 text-xs text-gray-600">
            <input type="checkbox" id="chart-color" checked> йўңиүІ
          </label>
        </div>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">ж•°жҚ®пјҲжҜҸиЎҢ: ж Үзӯҫ,ж•°еҖјпјү</label>
        <textarea id="chart-data" rows="8" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" spellcheck="false">Chrome,65
Safari,18
Firefox,8
Edge,5
Opera,2
е…¶д»–,2</textarea>
      </div>

      <div id="chart-output" class="hidden">
        <label class="block text-sm font-medium text-gray-700 mb-1">ASCII еӣҫиЎЁ</label>
        <pre id="chart-result" class="w-full border border-gray-300 rounded-lg p-4 font-mono text-sm bg-gray-50 overflow-x-auto whitespace-pre leading-relaxed"></pre>
        <div class="mt-2 text-xs text-gray-500" id="chart-stats"></div>
      </div>
    </div>
  </div>
</div>

<script>
// CJK-aware pad: дёӯж–Үеӯ—з¬Ұи®Ў 2 е®ҪеәҰпјҢдҝқжҢҒеҜ№йҪҗ
function padCJK(s, len) {
  const w = [...s].reduce((sum, c) => sum + (c.charCodeAt(0) > 255 ? 2 : 1), 0);
  return s + ' '.repeat(Math.max(0, len - w));
}

const COLORS = ['\x1b[38;5;196m', '\x1b[38;5;208m', '\x1b[38;5;226m', '\x1b[38;5;46m', '\x1b[38;5;39m', '\x1b[38;5;93m', '\x1b[38;5;201m', '\x1b[38;5;51m'];
const COLOR_CHARS = ['рҹ”ҙ', 'рҹҹ ', 'рҹҹЎ', 'рҹҹў', 'рҹ”ө', 'рҹҹЈ', 'рҹҹЈ', 'рҹ”ө'];
const BARS = ['в–‘', 'в–’', 'в–“', 'в–Ҳ'];

function generateChart() {
  const type = document.getElementById('chart-type').value;
  const width = parseInt(document.getElementById('chart-width').value) || 50;
  const sortBy = document.getElementById('chart-sort').value;
  const showVal = document.getElementById('chart-showval').value;
  const useColor = document.getElementById('chart-color').checked;

  const text = document.getElementById('chart-data').value;
  const lines = text.split('\n').map(l => l.trim()).filter(l => l);
  let data = lines.map(l => {
    const parts = l.split(',').map(s => s.trim());
    return { label: parts[0], value: parseFloat(parts[1]) || 0 };
  });

  if (data.length === 0) return;

  if (sortBy === 'desc') data.sort((a, b) => b.value - a.value);
  else if (sortBy === 'asc') data.sort((a, b) => a.value - b.value);

  const maxVal = Math.max(...data.map(d => d.value));
  const total = data.reduce((s, d) => s + d.value, 0);
  const maxLabelLen = Math.max(...data.map(d => [...d.label].reduce((s,c) => s + (c.charCodeAt(0) > 255 ? 2 : 1), 0)));

  let result;
  switch (type) {
    case 'pie': result = generatePie(data, maxLabelLen, useColor); break;
    case 'line': result = generateLine(data, maxVal, maxLabelLen, width, showVal); break;
    case 'stack': result = generateStack(data, maxVal, maxLabelLen, width, showVal); break;
    default: result = generateBar(type, data, maxVal, maxLabelLen, width, showVal, useColor);
  }

  const output = document.getElementById('chart-output');
  output.classList.remove('hidden');
  document.getElementById('chart-result').textContent = result;
  document.getElementById('chart-stats').textContent = `${data.length} йЎ№ В· жңҖеӨ§еҖј ${maxVal} В· жҖ»е’Ң ${total}`;
}

function generateBar(type, data, maxVal, maxLabelLen, width, showVal, useColor) {
  const isHbar = type === 'hbar';
  let lines = [];

  for (let i = 0; i < data.length; i++) {
    const { label, value } = data[i];
    const pct = maxVal > 0 ? value / maxVal : 0;
    const barLen = Math.round(pct * width);
    const bar = BARS[3].repeat(barLen);
    const colorTag = useColor ? COLOR_CHARS[i % COLOR_CHARS.length] : 'в–Ҳ';
    const valStr = showVal === 'yes' ? ` ${value}` : '';

    if (isHbar) {
      lines.push(`${padCJK(label, maxLabelLen)} в”Ӯ${colorTag}${bar.repeat(3)}${valStr}`);
    } else {
      // Vertical bar
      lines.push(`${padCJK(label, maxLabelLen)} в”Ӯ${colorTag}${bar.repeat(3)}${valStr}`);
    }
  }

  return lines.join('\n');
}

function generateLine(data, maxVal, maxLabelLen, width, showVal) {
  if (data.length === 0) return 'ж— ж•°жҚ®';
  const h = 12;
  const lines = [];
  // Y axis
  for (let y = h - 1; y >= 0; y--) {
    const pct = y / (h - 1);
    const val = (maxVal * (1 - pct)).toFixed(0);
    const row = [String(val).padStart(4) + ' в”Ө'];
    for (let x = 0; x < data.length; x++) {
      const d = data[x];
      const thisPct = d.value / maxVal;
      const displayChar = thisPct >= pct ? 'в—Ҹ' : thisPct >= pct - 1/h ? 'В·' : ' ';
      row.push(displayChar);
    }
    lines.push(row.join(' '));
  }
  // X axis
  lines.push('     в””' + data.map(() => 'в”Җ').join('в”Җ'));
  lines.push('     ' + data.map((d,i) => String(i+1).padEnd(1)).join(' '));
  // Labels
  lines.push('');
  data.forEach((d, i) => lines.push(`  ${i+1}. ${d.label}${showVal === 'yes' ? ' (' + d.value + ')' : ''}`));
  return lines.join('\n');
}

function generateStack(data, maxVal, maxLabelLen, width, showVal) {
  if (data.length === 0) return 'ж— ж•°жҚ®';
  const total = data.reduce((s, d) => s + d.value, 0);
  return data.map((d, i) => {
    const pct = d.value / (maxVal || 1);
    const barLen = Math.round(pct * width);
    const bar = COLOR_CHARS[i % COLOR_CHARS.length].repeat(barLen);
    const pctStr = ((d.value / (total || 1)) * 100).toFixed(1) + '%';
    return `${padCJK(d.label, maxLabelLen)} в”Ӯ${bar} ${showVal === 'yes' ? d.value + ' (' + pctStr + ')' : ''}`;
  }).join('\n');
}

function generatePie(data, maxLabelLen, useColor) {
  const total = data.reduce((s, d) => s + d.value, 0);
  if (total === 0) return 'ж— ж•°жҚ®';

  const size = 10;
  const grid = Array.from({ length: size * 2 + 1 }, () => Array(size * 2 + 1).fill(' '));

  const cx = size, cy = size, r = size - 0.5;
  let angles = [];
  let currentAngle = -Math.PI / 2;

  for (let i = 0; i < data.length; i++) {
    const sliceAngle = (data[i].value / total) * Math.PI * 2;
    angles.push({ start: currentAngle, end: currentAngle + sliceAngle, idx: i });
    currentAngle += sliceAngle;
  }

  for (let y = 0; y <= size * 2; y++) {
    for (let x = 0; x <= size * 2; x++) {
      const dx = x - cx, dy = y - cy;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist > r - 0.5 && dist < r + 0.5) {
        grid[y][x] = 'в—Ӣ';
      } else if (dist <= r - 0.5) {
        const angle = Math.atan2(dy, dx);
        for (const a of angles) {
          let aStart = a.start, aEnd = a.end;
          if (aStart <= angle && angle <= aEnd) {
            grid[y][x] = useColor ? 'в—Ҹ' : 'в—Ҹ';
            break;
          } else if (aStart > aEnd && (angle >= aStart || angle <= aEnd)) {
            grid[y][x] = useColor ? 'в—Ҹ' : 'в—Ҹ';
            break;
          }
        }
      }
    }
  }

  let result = grid.map(row => row.join('')).join('\n');
  result += '\n';

  for (let i = 0; i < data.length; i++) {
    const pct = ((data[i].value / total) * 100).toFixed(1);
    const colorTag = useColor ? COLOR_CHARS[i % COLOR_CHARS.length] : 'в¬Ө';
    result += `\n${colorTag} ${padCJK(data[i].label, maxLabelLen)} ${pct}% (${data[i].value})`;
  }

  return result;
}

function copyResult() {
  const text = document.getElementById('chart-result').textContent;
  if (!text) return;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('[onclick="copyResult()"]');
    btn.textContent = 'вң… е·ІеӨҚеҲ¶';
    setTimeout(() => btn.textContent = 'рҹ“Ӣ еӨҚеҲ¶', 1500);
  })
      .catch(function(err) { console.error(err); });;
}

function clearAll() {
  document.getElementById('chart-data').value = '';
  document.getElementById('chart-output').classList.add('hidden');
}
</script>
