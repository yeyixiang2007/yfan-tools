<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <!-- Mode Tabs -->
      <div class="flex flex-wrap gap-2 mb-6">
        <button id="tab-encode" onclick="switchMode('encode')" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium">编码 (→ Base64)</button>
        <button id="tab-decode" onclick="switchMode('decode')" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-300">解码 (Base64 →)</button>
        <button id="tab-file-encode" onclick="switchMode('file-encode')" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-300">文件→Base64</button>
        <button id="tab-file-decode" onclick="switchMode('file-decode')" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-300">Base64→文件</button>
      </div>

      <!-- 文本输入区 -->
      <div id="text-input-area">
        <div class="mb-4">
          <label id="input-label" class="block text-sm font-medium text-gray-700 mb-1">输入文本</label>
          <textarea id="base64-input" rows="6" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="输入要编码的文本..."></textarea>
        </div>

        <div class="flex flex-wrap gap-2 mb-4">
          <button onclick="convert()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium" id="convert-btn">编码</button>
          <button onclick="swap()" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 text-sm font-medium">上下互换</button>
        </div>
      </div>

      <!-- 文件上传区 -->
      <div id="file-area" class="hidden">
        <div id="file-drop-zone" class="mb-4 border-2 border-dashed border-gray-300 rounded-lg p-8 text-center text-gray-400 text-sm cursor-pointer hover:border-blue-400 hover:text-blue-500 transition"
             onclick="document.getElementById('file-picker').click()"
             ondragover="this.classList.add('border-blue-500','bg-blue-50')"
             ondragleave="this.classList.remove('border-blue-500','bg-blue-50')"
             ondrop="handleFileDrop(event)">
          📂 拖拽文件到此处，或点击选择文件<br>
          <span class="text-xs">最大 10MB</span>
        </div>
        <input id="file-picker" type="file" class="hidden" onchange="handleFileSelect(this)">
        <div id="file-info" class="hidden mb-4 p-3 bg-gray-50 rounded-lg text-sm text-gray-600"></div>
        <div id="file-output" class="hidden mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Base64 结果</label>
          <div class="relative">
            <textarea id="base64-file-result" rows="5" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-xs bg-gray-50 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" readonly></textarea>
            <button onclick="copyFileResult()" class="absolute top-2 right-2 px-3 py-1 bg-white border border-gray-300 text-gray-600 rounded text-xs hover:bg-gray-50">复制</button>
          </div>
        </div>
      </div>

      <!-- Base64 转文件区 -->
      <div id="decode-file-area" class="hidden">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">输入 Base64 字符串</label>
          <textarea id="base64-decode-input" rows="5" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="粘贴 Base64 编码（支持 data: URI 格式）..."></textarea>
        </div>
        <div class="mb-4">
          <input id="decode-file-name" class="w-full border border-gray-300 rounded-lg p-2 text-sm" placeholder="输出文件名（如 image.png）">
        </div>
        <button onclick="decodeFile()" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium mb-4">解码并下载</button>
      </div>

      <!-- 文本结果区 -->
      <div id="text-output-area">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">结果</label>
          <div class="relative">
            <textarea id="base64-output" rows="6" class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm bg-gray-50 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" readonly></textarea>
            <button onclick="copyOutput()" class="absolute top-2 right-2 px-3 py-1 bg-white border border-gray-300 text-gray-600 rounded text-xs hover:bg-gray-50">复制</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
let mode = 'encode';

function switchMode(newMode) {
  mode = newMode;
  // Tabs
  ['encode','decode','file-encode','file-decode'].forEach(m => {
    const el = document.getElementById('tab-' + m);
    el.className = m === newMode ? 'px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium' : 'px-4 py-2 bg-gray-200 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-300';
  });

  // Show/hide areas
  const textInput = document.getElementById('text-input-area');
  const textOutput = document.getElementById('text-output-area');
  const fileArea = document.getElementById('file-area');
  const decodeFileArea = document.getElementById('decode-file-area');

  textInput.classList.toggle('hidden', newMode === 'file-encode' || newMode === 'file-decode');
  textOutput.classList.toggle('hidden', newMode === 'file-encode' || newMode === 'file-decode');
  fileArea.classList.toggle('hidden', newMode !== 'file-encode');
  decodeFileArea.classList.toggle('hidden', newMode !== 'file-decode');

  if (newMode === 'encode') {
    document.getElementById('input-label').textContent = '输入文本';
    document.getElementById('convert-btn').textContent = '编码';
    document.getElementById('base64-input').placeholder = '输入要编码的文本...';
  } else if (newMode === 'decode') {
    document.getElementById('input-label').textContent = '输入 Base64';
    document.getElementById('convert-btn').textContent = '解码';
    document.getElementById('base64-input').placeholder = '输入 Base64 字符串...';
  }
}

function convert() {
  const input = document.getElementById('base64-input').value;
  const output = document.getElementById('base64-output');
  if (!input) { output.value = ''; return; }
  try {
    if (mode === 'encode') {
      output.value = btoa(unescape(encodeURIComponent(input)));
    } else {
      output.value = decodeURIComponent(escape(atob(input.trim())));
    }
  } catch (e) {
    output.value = '错误: ' + e.message;
  }
}

function swap() {
  const input = document.getElementById('base64-input');
  const output = document.getElementById('base64-output');
  const tmp = input.value;
  input.value = output.value;
  output.value = '';
  if (mode === 'encode') switchMode('decode');
  else switchMode('encode');
}

function copyOutput() {
  const text = document.getElementById('base64-output').value;
  if (!text) return;
  navigator.clipboard.writeText(text).then(() => {
    const btn = event.target;
    const orig = btn.textContent;
    btn.textContent = '✅';
    setTimeout(() => btn.textContent = orig, 1500);
  })
      .catch(function(err) { console.error(err); });;
}

// ── 文件 → Base64 ──
function handleFileDrop(e) {
  e.preventDefault();
  const zone = document.getElementById('file-drop-zone');
  zone.classList.remove('border-blue-500', 'bg-blue-50');
  if (e.dataTransfer.files.length > 0) processFile(e.dataTransfer.files[0]);
}

function handleFileSelect(el) {
  if (el.files.length > 0) processFile(el.files[0]);
  el.value = '';
}

function processFile(file) {
  if (file.size > 10 * 1024 * 1024) {
    alert('文件超过 10MB 限制');
    return;
  }
  document.getElementById('file-info').classList.remove('hidden');
  document.getElementById('file-info').innerHTML = `📄 ${file.name} (${(file.size / 1024).toFixed(1)} KB)`;

  const reader = new FileReader();
  reader.onload = function(e) {
    const base64 = e.target.result; // data: URI
    document.getElementById('file-output').classList.remove('hidden');
    document.getElementById('base64-file-result').value = base64;
  };
  reader.readAsDataURL(file);
}

function copyFileResult() {
  const text = document.getElementById('base64-file-result').value;
  if (!text) return;
  navigator.clipboard.writeText(text).then(() => {
    const btn = event.target;
    const orig = btn.textContent;
    btn.textContent = '✅';
    setTimeout(() => btn.textContent = orig, 1500);
  })
      .catch(function(err) { console.error(err); });;
}

// ── Base64 → 文件下载 ──
function decodeFile() {
  const input = document.getElementById('base64-decode-input').value.trim();
  const fileName = document.getElementById('decode-file-name').value.trim() || 'download';

  if (!input) { alert('请输入 Base64 字符串'); return; }

  try {
    let data = input;
    let mime = '';
    // 检测 data: URI
    const match = data.match(/^data:([^;]+);base64,(.+)$/);
    if (match) {
      mime = match[1];
      data = match[2];
    } else {
      // 尝试推断 MIME
      const header = atob(data.substring(0, 20));
      if (header.startsWith('\x89PNG')) mime = 'image/png';
      else if (header.startsWith('\xff\xd8')) mime = 'image/jpeg';
      else if (header.startsWith('GIF')) mime = 'image/gif';
      else if (header.startsWith('PDF')) mime = 'application/pdf';
      else mime = 'application/octet-stream';
    }

    const binary = atob(data.replace(/\s/g, ''));
    const bytes = new Uint8Array(binary.length);
    for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
    const blob = new Blob([bytes], { type: mime });
    const url = URL.createObjectURL(blob);

    const a = document.createElement('a');
    a.href = url;

    // 自动选择扩展名
    let ext = fileName.includes('.') ? '' : '.bin';
    if (!fileName.includes('.')) {
      if (mime.startsWith('image/png')) ext = '.png';
      else if (mime.startsWith('image/jpeg')) ext = '.jpg';
      else if (mime.startsWith('image/gif')) ext = '.gif';
      else if (mime.startsWith('application/pdf')) ext = '.pdf';
    }
    a.download = fileName + ext;
    a.click();
    URL.revokeObjectURL(url);
  } catch (e) {
    alert('解码失败: ' + e.message);
  }
}
</script>
