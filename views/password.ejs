<%- /* content block for layout */ '' %>
<% var content = ''; %>

<div>
  <div class="mb-6">
    <a href="/" class="text-sm text-blue-500 hover:text-blue-700">&larr; 返回首页</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-3xl"><%- tool.icon %></span>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%- tool.name %></h1>
        <p class="text-sm text-gray-500"><%- tool.desc %></p>
      </div>
    </div>

    <div class="border-t border-gray-100 pt-6 mt-2">
      <!-- 配置 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">密码长度</label>
          <div class="flex items-center gap-3">
            <input id="pw-length" type="range" min="4" max="64" value="16" class="flex-1 accent-blue-600" oninput="document.getElementById('pw-length-val').textContent = this.value">
            <span id="pw-length-val" class="text-sm font-mono text-gray-700 w-8 text-right">16</span>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">生成数量</label>
          <div class="flex items-center gap-3">
            <input id="pw-count" type="range" min="1" max="20" value="5" class="flex-1 accent-blue-600" oninput="document.getElementById('pw-count-val').textContent = this.value">
            <span id="pw-count-val" class="text-sm font-mono text-gray-700 w-8 text-right">5</span>
          </div>
        </div>
      </div>

      <!-- 字符集 -->
      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-2">字符集</label>
        <div class="flex flex-wrap gap-4">
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="pw-upper" type="checkbox" checked class="rounded text-blue-600 focus:ring-blue-500">
            <span class="text-sm text-gray-600">大写字母 <span class="font-mono text-xs text-gray-400">A-Z</span></span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="pw-lower" type="checkbox" checked class="rounded text-blue-600 focus:ring-blue-500">
            <span class="text-sm text-gray-600">小写字母 <span class="font-mono text-xs text-gray-400">a-z</span></span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="pw-digit" type="checkbox" checked class="rounded text-blue-600 focus:ring-blue-500">
            <span class="text-sm text-gray-600">数字 <span class="font-mono text-xs text-gray-400">0-9</span></span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="pw-symbol" type="checkbox" class="rounded text-blue-600 focus:ring-blue-500">
            <span class="text-sm text-gray-600">特殊字符 <span class="font-mono text-xs text-gray-400">!@#$%</span></span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="pw-ambiguous" type="checkbox" checked class="rounded text-blue-600 focus:ring-blue-500">
            <span class="text-sm text-gray-600">排除易混淆 <span class="font-mono text-xs text-gray-400">0OIl1</span></span>
          </label>
        </div>
      </div>

      <button onclick="generatePasswords()" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm font-medium mb-6">🔑 生成密码</button>

      <!-- 结果 -->
      <div id="pw-result" class="hidden">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-sm font-semibold text-gray-700">生成的密码</h3>
          <button onclick="copyAllPasswords()" class="text-xs px-3 py-1 bg-white border border-gray-300 rounded hover:bg-gray-50">📋 复制全部</button>
        </div>
        <div id="pw-list" class="space-y-2"></div>
        <div class="mt-4 p-3 bg-blue-50 rounded-lg text-xs text-blue-700">
          💡 点击单个密码旁边的复制按钮可以复制单个密码。建议使用浏览器密码管理器保存。
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function generatePasswords() {
  const length = parseInt(document.getElementById('pw-length').value);
  const count = parseInt(document.getElementById('pw-count').value);
  const useUpper = document.getElementById('pw-upper').checked;
  const useLower = document.getElementById('pw-lower').checked;
  const useDigit = document.getElementById('pw-digit').checked;
  const useSymbol = document.getElementById('pw-symbol').checked;
  const excludeAmbiguous = document.getElementById('pw-ambiguous').checked;

  let chars = '';
  if (useUpper) chars += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  if (useLower) chars += 'abcdefghijklmnopqrstuvwxyz';
  if (useDigit) chars += '0123456789';
  if (useSymbol) chars += '!@#$%^&*()_+-=[]{}|;:,.<>?';

  if (excludeAmbiguous) {
    chars = chars.replace(/[0OIl1]/g, '');
  }

  if (!chars) {
    document.getElementById('pw-result').classList.remove('hidden');
    document.getElementById('pw-list').innerHTML = '<p class="text-red-500 text-sm">⚠️ 请至少选择一种字符集</p>';
    return;
  }

  const passwords = [];
  for (let i = 0; i < count; i++) {
    let pw = '';
    for (let j = 0; j < length; j++) {
      pw += chars[Math.floor(Math.random() * chars.length)];
    }
    // 确保至少包含每种选中的字符类型
    if (useUpper && !/[A-Z]/.test(pw)) {
      pw = pw.slice(0, -1) + 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'[Math.floor(Math.random() * 26)];
    }
    if (useLower && !/[a-z]/.test(pw)) {
      pw = pw.slice(0, -1) + 'abcdefghijklmnopqrstuvwxyz'[Math.floor(Math.random() * 26)];
    }
    if (useDigit && !/\d/.test(pw)) {
      pw = pw.slice(0, -1) + '0123456789'[Math.floor(Math.random() * 10)];
    }
    passwords.push(pw);
  }

  const resultDiv = document.getElementById('pw-result');
  const listDiv = document.getElementById('pw-list');
  resultDiv.classList.remove('hidden');

  listDiv.innerHTML = passwords.map((pw, i) => {
    const strength = getStrength(pw);
    const strengthColor = ['bg-red-100 text-red-700', 'bg-yellow-100 text-yellow-700', 'bg-green-100 text-green-700'][strength];
    const strengthLabel = ['弱', '中', '强'][strength];
    return '<div class="flex items-center justify-between p-3 bg-gray-50 border border-gray-200 rounded-lg group">' +
      '<div class="flex items-center gap-3">' +
        '<span class="text-xs text-gray-400 w-6">#' + (i+1) + '</span>' +
        '<code class="font-mono text-sm select-all">' + escapeHtml(pw) + '</code>' +
        '<span class="text-xs px-1.5 py-0.5 rounded ' + strengthColor + '">' + strengthLabel + '</span>' +
      '</div>' +
      '<button onclick="copyPassword(\'' + escapeHtml(pw) + '\', this)" class="text-xs px-2 py-1 bg-white border border-gray-300 rounded hover:bg-gray-50 opacity-0 group-hover:opacity-100 transition">📋 复制</button>' +
    '</div>';
  }).join('');
}

function getStrength(pw) {
  let score = 0;
  if (pw.length >= 12) score++;
  if (pw.length >= 16) score++;
  if (/[a-z]/.test(pw) && /[A-Z]/.test(pw)) score++;
  if (/\d/.test(pw)) score++;
  if (/[^a-zA-Z0-9]/.test(pw)) score++;
  return Math.min(2, Math.floor(score / 2));
}

function copyPassword(text, btn) {
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = '✅ 已复制';
    setTimeout(() => { btn.textContent = '📋 复制'; }, 2000);
  }).catch(() => {
    // fallback
    const ta = document.createElement('textarea');
    ta.value = text;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    btn.textContent = '✅ 已复制';
    setTimeout(() => { btn.textContent = '📋 复制'; }, 2000);
  });
}

function copyAllPasswords() {
  const listDiv = document.getElementById('pw-list');
  const codes = listDiv.querySelectorAll('code');
  const text = Array.from(codes).map(c => c.textContent).join('\n');
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('#pw-result .flex .text-xs');
    btn.textContent = '✅ 已复制全部';
    setTimeout(() => { btn.textContent = '📋 复制全部'; }, 2000);
  })
      .catch(function(err) { console.error(err); });;
}

function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, function(m) {
    return {'&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'}[m];
  });
}
</script>
